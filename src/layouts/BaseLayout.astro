---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getLocaleFromPath } from '../i18n/utils';
import type { Locale } from '../i18n/strings';

interface Props {
  title: string;
  description?: string;
  locale?: Locale;
  ogImage?: string;
  noindex?: boolean;
}

const pathname = Astro.url.pathname;
const detectedLocale = getLocaleFromPath(pathname);
const {
  title,
  description = 'entrópica is an energy-first architecture lab based in panamá. cool buildings in hot places.',
  locale = detectedLocale,
  ogImage = '/entropica-dark.png',
  noindex = false,
} = Astro.props;

const fullTitle = title.includes('entrópica') ? title : `${title} · entrópica`;
const canonical = new URL(pathname, Astro.site).toString();
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/png" href="/favicon.png" />

    {/* material symbols outlined — weight 300 to match brand's light feel */}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,300,0,0" />

    {/* opengraph + twitter */}
    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL(ogImage, Astro.site).toString()} />
    <meta property="og:locale" content={locale === 'es' ? 'es_PA' : 'en_US'} />
    <meta name="twitter:card" content="summary_large_image" />

    <meta name="theme-color" content="#f4f1ea" />
  </head>
  <body>
    <a class="skip" href="#main">skip to content</a>
    <Header locale={locale} pathname={pathname} />
    <main id="main">
      <slot />
    </main>
    <Footer locale={locale} />
  </body>
</html>
