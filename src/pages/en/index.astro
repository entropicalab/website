---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { localized, tr } from '../../i18n/utils';

const locale = 'en' as const;
const t = tr(locale);

const allProjects = await getCollection('projects', ({ data }) => data.locale === locale);
const featured = allProjects
  .filter((p) => p.data.featured)
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));

const services = [
  { eyebrow: '// 01', title: 'concept design', icon: 'architecture', body: 'orientation, massing, and program tested against the climate before the section is committed.' },
  { eyebrow: '// 02', title: 'architectural design + coordination', icon: 'dashboard_customize', body: 'full architectural delivery, including complementary engineering disciplines.' },
  { eyebrow: '// 03', title: 'permitting + documentation', icon: 'description', body: 'construction documents that pass review and that the contractor can actually build.' },
  { eyebrow: '// 04', title: 'energy + performance advisory', icon: 'monitoring', body: 'envelope simulation, daylight studies, leed / edge support, as a standalone or in-house service.' },
];

const problems = [
  { p: 'high energy use', s: 'solar control, envelope strategy, and system alignment.', icon: 'bolt' },
  { p: 'overheating + comfort complaints', s: 'shading, air movement, passive cooling strategies.', icon: 'device_thermostat' },
  { p: 'humidity + indoor air issues', s: 'moisture load management and detailing for durability.', icon: 'humidity_mid' },
  { p: 'coastal exposure + corrosion', s: 'material selection and protective detailing.', icon: 'waves' },
  { p: 'poor daylight or glare', s: 'daylight shaping and controlled solar access.', icon: 'wb_sunny' },
  { p: 'costly maintenance', s: 'simpler systems and durable assemblies.', icon: 'build' },
];

const manifesto = ['shade', 'airflow', 'moisture', 'durability', 'thermal mass', 'energy'];

const businessSchema = {
  '@context': 'https://schema.org',
  '@type': 'ArchitecturalService',
  name: 'entrópica',
  legalName: 'watts & matter consulting, s. e.p.',
  description: 'energy-led tropical and bioclimatic architecture studio in panamá, central america.',
  url: 'https://entropica-lab.com/en/',
  email: 'info@entropica-lab.com',
  telephone: '+507 6944-4740',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'ph plaza mar, paitilla',
    addressLocality: 'panama city',
    addressCountry: 'PA',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 8.974904602770444,
    longitude: -79.51278964689152,
  },
  hasMap: 'https://maps.app.goo.gl/v1nWCHivFs7zPgrj9',
  sameAs: ['https://maps.app.goo.gl/v1nWCHivFs7zPgrj9'],
  areaServed: {
    '@type': 'Country',
    name: 'Panama',
  },
  knowsLanguage: ['es', 'en'],
};

const clients = [
  {
    cat: 'real estate',
    items: ['promotora azul rubí', 'linton bay', 'regor assets'],
  },
  {
    cat: 'commercial',
    items: ['global bank', 'festieventos', 'jolly roger diving', 'atn polaris', 'servicios carlos', 'estrella azul', 'us pharmacy group', 'kart 21', 'eurostone', 'current technologies', 'agrupetrol'],
  },
  {
    cat: 'hospitality',
    items: ['donde josé', 'fonda lo que hay', 'durán coffee select', 'wall st. bar and lounge', 'lung fung', 'dainer 16', 'hostales selina', 'esa flaca rica'],
  },
  {
    cat: 'institutional',
    items: ['wirtschaftsuniversität wien', 'santuario nacional', 'anep', 'universidad de panamá', 'municipio de san miguelito', 'ministerio público'],
  },
  {
    cat: 'consulting',
    items: ['soba design', 'rancho grande', 'george moreno & partners', 'labhaus studio', 'forza creativa', 'sousa design architects boston'],
  },
];
---

<BaseLayout
  title="entrópica · energy-led tropical architecture studio in panamá"
  description="entrópica is an energy-led tropical architecture studio in panamá, central america. we use climate science and building thermodynamics to design cool buildings in hot places."
  locale={locale}
>
  <script type="application/ld+json" set:html={JSON.stringify(businessSchema)} />
  <!-- ============ hero ============ -->
  <section class="hero">
    <div class="site-wrap">
      <div class="hero-grid">
        <div class="hero-eb">// tropical architecture studio · est. 2020</div>
        <h1 class="hero-h">
          energy-led tropical<br />
          architecture.
        </h1>
        <p class="hero-lede">
          entrópica is a tropical architecture studio in panamá. the sun, the heat,
          and the humidity determine the energy cost of a project. that is our starting
          point for design.
        </p>
        <div class="hero-ctas">
          <a class="btn amber" href={localized('/projects', locale)}>
            {t('cta.viewWork')}
            <span class="arrow-tail" aria-hidden="true"></span>
          </a>
          <a class="btn" href={localized('/contact', locale)}>{t('cta.contact')}</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ manifesto strip (KEEP) ============ -->
  <section class="manifesto-strip">
    <div class="site-wrap">
      <div class="manifesto-eb">// performance is design material</div>
      <div class="manifesto-grid">
        {manifesto.map((word) => (
          <div class="manifesto-cell">
            {word} <span class="amber">is architecture.</span>
          </div>
        ))}
      </div>
      <p class="manifesto-note">
        the things temperate-climate practice treats as afterthoughts, shade,
        airflow, moisture, energy, are, for us, the design material itself. the
        building is not a container for performance. the performance is the building.
        this is
        <a class="inline-link" href={localized('/blog/sustainable-architecture-panama', locale)}>bioclimatic architecture</a>
        for the tropics.
      </p>
    </div>
  </section>

  <!-- ============ what does that mean? · measurable upside ============ -->
  <section class="block measurable">
    <div class="site-wrap">
      <div class="measurable-head">
        <div class="eyebrow">// what does that mean?</div>
        <h2 class="block-h">designing from the climate has measurable results.</h2>
      </div>

      <div class="measurable-grid">
        {featured.map((p) => (
          <a class="measurable-card" href={localized(`/projects/${p.data.slug}`, locale)}>
            <div class="m-card-photo">
              {p.data.heroImage && <img src={p.data.heroImage} alt={p.data.title} loading="lazy" />}
            </div>
            {p.data.metric && (
              <div class="m-card-metric">
                <span class="m-num">{p.data.metric.value}<span class="m-unit">{p.data.metric.unit}</span></span>
                <span class="m-label">{p.data.metric.label}</span>
              </div>
            )}
            <div class="m-card-info">
              <div class="m-title">{p.data.title}</div>
              <div class="m-meta">
                <span>{p.data.area}</span><span class="sep">·</span>
                <span>{p.data.typology}</span><span class="sep">·</span>
                <span>{p.data.location}</span><span class="sep">·</span>
                <span>{p.data.year}</span>
              </div>
            </div>
          </a>
        ))}
      </div>

      <div class="measurable-foot">
        <a class="btn" href={localized('/projects', locale)}>
          {t('cta.viewWork')}
          <span class="arrow-tail" aria-hidden="true"></span>
        </a>
      </div>
    </div>
  </section>

  <!-- ============ what does that mean? · measurable downside ============ -->
  <section class="block downside alt">
    <div class="site-wrap">
      <div class="downside-grid">
        <div class="downside-left">
          <div class="eyebrow">// what does that mean?</div>
          <h2 class="block-h">ignoring the climate has measurable results too.</h2>
        </div>
        <div class="downside-right">
          <div class="big-stat">
            <span class="big-num">30<span class="dash">–</span>50<span class="big-unit">%</span></span>
            <p class="big-stat-line">more in operative costs over the lifetime of the building.<sup>*</sup></p>
            <p class="big-stat-prompt">how much would you rather not pay?</p>
            <p class="big-stat-source"><sup>*</sup> ashrae · iea cooling report, 2024.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ how do we do it? ============ -->
  <section class="block howdoit">
    <div class="site-wrap">
      <div class="howdoit-head">
        <div class="eyebrow">// how do we do it?</div>
        <h2 class="block-h">we design with energy simulations, to avoid:</h2>
      </div>
      <div class="problems-grid">
        {problems.map((p) => (
          <div class="problem">
            <span class="material-symbols-outlined icon-md icon-amber prob-icon">{p.icon}</span>
            <div class="prob-name">{p.p}</div>
            <div class="prob-soln">{p.s}</div>
          </div>
        ))}
      </div>
      <p class="howdoit-punch">
        because you wouldn't build without knowing how the building will look, even just from
        a render. <span class="amber-text">same thing, but for energy.</span>
      </p>
    </div>
  </section>

  <!-- ============ our offering ============ -->
  <section class="block services alt">
    <div class="site-wrap">
      <div class="services-head">
        <div class="eyebrow">// our offering</div>
        <h2 class="block-h">architectural services, energy-led.</h2>
        <p class="block-sub">from concept to construction, energy is a design criterion from day one.</p>
      </div>

      <div class="services-grid">
        {services.map((s) => (
          <div class="svc">
            <span class="material-symbols-outlined icon-md icon-amber svc-icon">{s.icon}</span>
            <div class="svc-eb">{s.eyebrow}</div>
            <h3 class="svc-title">{s.title}</h3>
            <p class="svc-body">{s.body}</p>
          </div>
        ))}
      </div>

      <div class="services-foot">
        <a class="btn" href={localized('/services', locale)}>more on services</a>
      </div>
    </div>
  </section>

  <!-- ============ our experience ============ -->
  <section class="block experience">
    <div class="site-wrap">
      <div class="experience-head">
        <div class="eyebrow">// our experience</div>
        <h2 class="block-h">some of the clients we've earned.</h2>
      </div>
      <div class="clients-grid">
        {clients.map((c) => (
          <div class="client-col">
            <div class="client-cat">{c.cat}</div>
            <ul class="client-list">
              {c.items.map((name) => (<li>{name}</li>))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ founder ============ -->
  <section class="block founder alt">
    <div class="site-wrap">
      <div class="founder-grid">
        <div class="founder-portrait">
          <img src="/jose.png" alt="josé barría" />
        </div>
        <div class="founder-body">
          <div class="eyebrow">// founder</div>
          <h2 class="block-h">josé barría.</h2>
          <p class="founder-lede">
            registered architect and founder of entrópica, a studio guided by energy
            performance in tropical climates.
          </p>
          <p class="founder-body-p">
            his work spans the americas, asia, africa, and europe. he taught and researched
            at the panamá green building council in 2013, co-founded pentagrama estudio de
            diseño in 2015, and in 2018 co-founded acta, panamá's first sustainable
            innovation zone. since 2026, he is part of mat, the tropical architecture
            movement. outside entrópica, he is a partner at trimpacta, the corporate side
            of the same problem: water footprint, carbon, and sustainability reporting.
          </p>
          <a class="btn" href={localized('/about', locale)}>
            more about the studio
            <span class="arrow-tail" aria-hidden="true"></span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ let's get to work ============ -->
  <section class="closing-cta">
    <div class="site-wrap">
      <div class="closing-inner">
        <div class="eyebrow">// let's get to work</div>
        <h2 class="closing-h">
          let's make cool buildings<br />
          in hot places.
        </h2>
        <div class="closing-ctas">
          <a class="btn amber" href={localized('/contact', locale)}>
            {t('cta.contact')}
            <span class="arrow-tail" aria-hidden="true"></span>
          </a>
          <a class="contact-line" href="mailto:info@entropica-lab.com">info@entropica-lab.com</a>
          <a class="contact-line" href="https://wa.me/50769444740" target="_blank" rel="noopener">whatsapp · +507 6944-4740</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ============ hero ============ */
  .hero { padding: 120px 0 96px; }
  .hero-grid { display: grid; gap: 32px; max-width: 980px; }
  .hero-eb {
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--mute-on-paper);
    font-weight: 400;
  }
  .hero-h {
    font-size: clamp(40px, 6vw, 76px);
    line-height: 0.98;
    letter-spacing: -0.03em;
    margin: 0;
    font-weight: 300;
    text-wrap: balance;
  }
  .hero-lede {
    font-size: clamp(17px, 1.6vw, 20px);
    line-height: 1.55;
    color: var(--mute-on-paper);
    max-width: 60ch;
    margin: 0;
    font-weight: 400;
  }
  .hero-ctas {
    display: flex;
    gap: 12px;
    margin-top: 8px;
    flex-wrap: wrap;
  }
  .hero-where {
    margin-top: 32px;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--mute-on-paper-2);
    font-weight: 400;
  }

  /* ============ manifesto strip ============ */
  .manifesto-strip {
    padding: 56px 0 72px;
    border-top: 1px solid var(--line-on-paper);
  }
  .manifesto-eb {
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--mute-on-paper);
    font-weight: 400;
    margin-bottom: 24px;
  }
  .manifesto-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border-top: 1px solid var(--line-on-paper);
    border-bottom: 1px solid var(--line-on-paper);
  }
  .manifesto-cell {
    padding: 22px 24px;
    font-size: clamp(18px, 1.8vw, 22px);
    line-height: 1.2;
    letter-spacing: -0.01em;
    font-weight: 300;
    border-right: 1px solid var(--line-on-paper);
    border-bottom: 1px solid var(--line-on-paper);
  }
  .manifesto-cell:nth-child(3n) { border-right: none; }
  .manifesto-cell:nth-last-child(-n+3) { border-bottom: none; }
  .manifesto-cell .amber { color: var(--amber); }
  .manifesto-note {
    margin-top: 20px;
    font-size: 14px;
    line-height: 1.65;
    color: var(--mute-on-paper);
    font-weight: 400;
    max-width: 64ch;
  }
  @media (max-width: 720px) {
    .manifesto-grid { grid-template-columns: 1fr 1fr; }
    .manifesto-cell:nth-child(3n) { border-right: 1px solid var(--line-on-paper); }
    .manifesto-cell:nth-child(2n) { border-right: none; }
    .manifesto-cell:nth-last-child(-n+3) { border-bottom: 1px solid var(--line-on-paper); }
    .manifesto-cell:nth-last-child(-n+2) { border-bottom: none; }
  }

  /* ============ generic block ============ */
  .block { padding: 80px 0; border-top: 1px solid var(--line-on-paper); }
  .block.alt { background: var(--paper-2); }
  .block-h {
    font-size: clamp(28px, 3.4vw, 40px);
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin: 0 0 24px;
    font-weight: 300;
    max-width: 26ch;
    text-wrap: balance;
  }
  .block-sub {
    font-size: 17px;
    line-height: 1.55;
    color: var(--mute-on-paper);
    margin: 0;
    max-width: 56ch;
    font-weight: 400;
  }

  /* ============ measurable upside (3 metric cards) ============ */
  .measurable-head { margin-bottom: 56px; }
  .measurable-head .eyebrow {
    font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase;
    font-weight: 400; margin-bottom: 16px;
  }
  .measurable-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  .measurable-card {
    display: flex;
    flex-direction: column;
    gap: 18px;
    color: inherit;
    text-decoration: none;
    transition: transform 0.2s;
  }
  .measurable-card:hover { transform: translateY(-2px); }
  .m-card-photo {
    aspect-ratio: 4 / 3;
    background: var(--paper-2);
    background-image: repeating-linear-gradient(135deg, rgba(0, 0, 0, 0.03) 0 12px, transparent 12px 24px);
    border: 1px solid var(--line-on-paper);
    position: relative;
    overflow: hidden;
  }
  .m-card-photo img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; display: block; }
  .m-card-metric {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding-top: 4px;
    border-top: 1px solid var(--line-on-paper);
    padding-top: 16px;
  }
  .m-num {
    font-size: clamp(40px, 4.5vw, 56px);
    color: var(--amber);
    font-feature-settings: 'tnum' 1, 'lnum' 1;
    letter-spacing: -0.03em;
    line-height: 1;
    font-weight: 300;
  }
  .m-unit { font-size: 0.55em; vertical-align: top; margin-left: 1px; }
  .m-label {
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--mute-on-paper);
    font-weight: 400;
  }
  .m-card-info { display: flex; flex-direction: column; gap: 4px; }
  .m-title {
    font-size: 18px;
    line-height: 1.2;
    font-weight: 400;
  }
  .m-meta {
    font-size: 11px;
    color: var(--mute-on-paper);
    font-weight: 400;
    line-height: 1.55;
  }
  .m-meta .sep { color: var(--mute-on-paper-2); margin: 0 6px; }
  .measurable-foot { margin-top: 48px; }

  @media (max-width: 900px) {
    .measurable-grid { grid-template-columns: 1fr; gap: 40px; }
  }

  /* ============ measurable downside (40-60% stat) ============ */
  .downside-grid {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 80px;
    align-items: center;
  }
  .downside-left .eyebrow {
    font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase;
    font-weight: 400; margin-bottom: 16px;
  }
  .big-stat { display: flex; flex-direction: column; gap: 18px; }
  .big-num {
    font-size: clamp(72px, 12vw, 160px);
    color: var(--amber);
    font-feature-settings: 'tnum' 1, 'lnum' 1;
    letter-spacing: -0.04em;
    line-height: 0.9;
    font-weight: 300;
    display: inline-block;
  }
  .big-num .dash {
    font-size: 0.6em;
    color: var(--ink-on-paper);
    margin: 0 0.05em;
    vertical-align: middle;
    font-weight: 400;
  }
  .big-num .big-unit { font-size: 0.4em; vertical-align: top; margin-left: 4px; }
  .big-stat-line {
    font-size: clamp(18px, 2vw, 24px);
    line-height: 1.3;
    margin: 0;
    color: var(--ink-on-paper);
    font-weight: 400;
    max-width: 32ch;
  }
  .big-stat-prompt {
    font-size: clamp(16px, 1.6vw, 19px);
    line-height: 1.4;
    margin: 0;
    color: var(--mute-on-paper);
    font-weight: 400;
    font-style: italic;
  }
  .big-stat-source {
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--mute-on-paper-2);
    font-weight: 400;
    margin: 8px 0 0;
  }
  @media (max-width: 900px) {
    .downside-grid { grid-template-columns: 1fr; gap: 32px; }
  }

  /* ============ how do we do it? ============ */
  .howdoit-head { margin-bottom: 48px; }
  .howdoit-head .eyebrow {
    font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase;
    font-weight: 400; margin-bottom: 16px;
  }
  .howdoit-punch {
    margin-top: 40px;
    font-size: clamp(18px, 1.8vw, 22px);
    line-height: 1.45;
    font-weight: 300;
    color: var(--ink-on-paper);
    max-width: 64ch;
  }
  .howdoit-punch .amber-text { color: var(--amber); }

  /* ============ problems strip ============ */
  .problems-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
  .problem {
    padding: 24px 28px;
    background: var(--paper);
    border: 1px solid var(--line-on-paper);
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .prob-icon { margin-bottom: 6px; }
  .prob-name {
    font-size: 16px;
    font-weight: 500;
    color: var(--ink-on-paper);
  }
  .prob-soln {
    font-size: 14px;
    color: var(--mute-on-paper);
    line-height: 1.6;
    font-weight: 400;
  }
  @media (max-width: 900px) { .problems-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 540px) { .problems-grid { grid-template-columns: 1fr; } }

  /* ============ services ============ */
  .services-head { margin-bottom: 48px; }
  .services-head .eyebrow {
    font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase;
    font-weight: 400; margin-bottom: 16px;
  }
  .services-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 16px;
  }
  .svc {
    background: var(--paper);
    border: 1px solid var(--line-on-paper);
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .svc-icon { margin-bottom: 4px; }
  .svc-eb {
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--mute-on-paper-2);
    font-weight: 400;
  }
  .svc-title {
    font-size: 16px;
    font-weight: 400;
    line-height: 1.2;
    margin: 0;
  }
  .svc-body {
    font-size: 13px;
    line-height: 1.55;
    color: var(--mute-on-paper);
    font-weight: 400;
    margin: 0;
  }
  .services-foot { margin-top: 40px; }
  @media (max-width: 1100px) { .services-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 600px) { .services-grid { grid-template-columns: 1fr; } }

  /* ============ experience (client list) ============ */
  .experience-head { margin-bottom: 48px; }
  .experience-head .eyebrow {
    font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase;
    font-weight: 400; margin-bottom: 16px;
  }
  .clients-grid {
