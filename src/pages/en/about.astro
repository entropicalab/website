---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { localized, tr } from '../../i18n/utils';

const locale = 'en' as const;
const t = tr(locale);

const work = [
  {
    role: 'partner',
    org: 'trimpacta',
    period: '2024-present',
    body: 'data-driven sustainability consulting for businesses and corporations. sustainability reports, water footprint, carbon accounting.',
  },
  {
    role: 'founder',
    org: 'entrópica',
    period: '2020-present',
    body: 'energy-first design studio. building performance simulations (energy+, openfoam, radiance), façade optimisation, daylight modelling. clients include developers, ngos, and multinational firms.',
  },
  {
    role: 'co-founder',
    org: 'acta sustainable innovation zone',
    period: '2018-2021',
    body: 'led sustainable planning strategies; coordinated and designed public space recovery projects; promoted sustainability-oriented city policy.',
  },
  {
    role: 'junior architect',
    org: 'erdy mchenry architecture · philadelphia, pa',
    period: '2017-2018',
    body: "design development and environmental analysis for mixed-use and institutional projects, including vanguard campus west's $76mm neptune building.",
  },
  {
    role: 'co-founder · design principal',
    org: 'pentagrama',
    period: '2013-2015 · 2018-2023',
    body: 'directed award-winning architectural projects (residential, commercial, institutional). managed design delivery, consultant coordination, and construction oversight.',
  },
  {
    role: 'research intern',
    org: 'panamá green building council',
    period: '2013',
    body: 'sustainability benchmarking, policy research, and early adoption of building performance tools in panamá.',
  },
];

const honors = [
  { year: '2024', name: 'dna · design awards paris', detail: 'winner, cultural architecture' },
  { year: '2023', name: 'moa panamá', detail: 'honorable mention' },
];

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'josé barría',
  url: 'https://entropica-lab.com/en/about',
  jobTitle: 'architect · founder',
  worksFor: { '@type': 'Organization', name: 'entrópica', url: 'https://entropica-lab.com' },
  alumniOf: [
    { '@type': 'CollegeOrUniversity', name: 'university of pennsylvania' },
    { '@type': 'CollegeOrUniversity', name: 'isthmus', address: { '@type': 'PostalAddress', addressCountry: 'PA' } },
  ],
  knowsAbout: ['tropical architecture', 'energy simulation', 'bioclimatic design', 'panamá'],
};
---

<BaseLayout
  title="about us · entrópica · tropical climate architect in panamá"
  description="entrópica is the work of josé barría, registered architect (jtia) and master of environmental building design (upenn). energy-led tropical architecture in panamá, republic of panama."
  locale={locale}
>
  <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
  <!-- ============ hero ============ -->
  <section class="hero">
    <div class="site-wrap">
      <div class="eyebrow">// about us</div>
      <h1 class="hero-h">
        something like a studio<br />
        and a lab.
      </h1>
      <p class="hero-lede">
        investigating and designing, finding the sensible way to create architecture
        in a changing climate.
      </p>
    </div>
  </section>

  <!-- ============ portrait + bio ============ -->
  <section class="bio">
    <div class="site-wrap">
      <div class="bio-grid">
        <div class="portrait">
          <img src="/jose.png" alt="josé barría" />
          <div class="portrait-caption">
            <div class="eyebrow">// leadership</div>
            <div class="name">josé barría</div>
            <div class="role">founder · architect · simulation lead</div>
          </div>
        </div>
        <div class="bio-text prose">
          <p class="lede">
            josé is the registered architect and founder of entrópica.
          </p>
          <p>
            his experience spans panamá and the united states, across residential,
            commercial, and institutional work, with a consistent focus on
            climate-responsive design and building performance. he has worked at design
            firms in philadelphia and panamá, taught and researched at the panamá green
            building council, and co-founded an early sustainable-design practice that
            laid the technical ground for entrópica.
          </p>
          <p>
            outside entrópica he is a partner at trimpacta, a sustainability-consulting
            practice that handles the corporate side of the same problem, water
            footprints, carbon accounting, and sustainability reporting for businesses
            that want the work done honestly.
          </p>

          <h2>education</h2>
          <ul>
            <li><b>master of environmental building design</b>, university of pennsylvania (2017)</li>
            <li><b>bachelor of architecture</b>, isthmus, panamá (2014)</li>
          </ul>

          <h2>honors</h2>
          <ul>
            {honors.map((h) => (
              <li>
                <b>{h.name}</b>, {h.detail} <span class="muted">({h.year})</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ work history ============ -->
  <section class="block">
    <div class="site-wrap">
      <div class="proof-head">
        <div class="eyebrow">// the work, before this work</div>
        <h2 class="block-h">selected experience.</h2>
      </div>

      <div class="cv-stack">
        {work.map((w) => (
          <article class="cv-row">
            <div class="cv-period">{w.period}</div>
            <div class="cv-meta">
              <div class="cv-role">{w.role}</div>
              <div class="cv-org">{w.org}</div>
            </div>
            <div class="cv-body">{w.body}</div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ why so much rain ============ -->
  <section class="block">
    <div class="site-wrap">
      <div class="two-col">
        <div class="col-eb"><div class="eyebrow">// why so much rain?</div></div>
        <div class="col-body">
          <h2 class="block-h">because climate is where the building starts.</h2>
          <div class="prose">
            <p>
              we often present our projects in rainy or overcast conditions on purpose. it
              is a reminder that the climate is the starting point, not a backdrop.
              performance begins with understanding the environmental realities a building
              will face: weather, light, and seasonal change shape comfort, energy use, and
              long-term resilience.
            </p>
            <p>
              by showing our designs in their true climatic context, we make a single
              point: beauty and efficiency are inseparable from place. our guide on
              <a class="inline-link" href={localized('/blog/sustainable-architecture-panama', locale)}>sustainable architecture in panamá</a>
              works through why this matters for the tropics.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ philosophy strip ============ -->
  <section class="block alt">
    <div class="site-wrap">
      <div class="philosophy-grid">
        <div>
          <div class="eyebrow">// principle 01</div>
          <h3 class="phil-h">passive first.</h3>
          <p class="phil-body">orientation, shading, insulation, glazing, optimised before any system is sized.</p>
        </div>
        <div>
          <div class="eyebrow">// principle 02</div>
          <h3 class="phil-h">simulate before drawing.</h3>
          <p class="phil-body">small models, asked early, beat one big model asked at the end.</p>
        </div>
        <div>
          <div class="eyebrow">// principle 03</div>
          <h3 class="phil-h">measure the move.</h3>
          <p class="phil-body">every claim has a number behind it, in the same units the client pays in.</p>
        </div>
        <div>
          <div class="eyebrow">// principle 04</div>
          <h3 class="phil-h">stay specific.</h3>
          <p class="phil-body">tropical means tropical. imported standards don't survive contact with panamá.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ CTA ============ -->
  <section class="closing-cta">
    <div class="site-wrap">
      <div class="closing-inner">
        <h2 class="closing-h">
          if any of this sounds like the project you're working on,<br />
          we should talk.
        </h2>
        <div class="closing-ctas">
          <a class="btn amber" href={localized('/contact', locale)}>
            {t('cta.contact')}
            <span class="arrow-tail" aria-hidden="true"></span>
          </a>
          <a class="contact-line" href="mailto:info@entropica-lab.com">info@entropica-lab.com</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding: 96px 0 64px;
  }
  .hero .eyebrow {
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin-bottom: 24px;
    font-weight: 400;
  }
  .hero-h {
    font-size: clamp(34px, 5vw, 60px);
    line-height: 1.05;
    letter-spacing: -0.025em;
    margin: 0 0 28px;
    font-weight: 300;
    max-width: 22ch;
    text-wrap: balance;
  }
  .hero-lede {
    font-size: clamp(17px, 1.4vw, 19px);
    line-height: 1.6;
    color: var(--mute-on-paper);
    max-width: 64ch;
    margin: 0;
    font-weight: 300;
  }

  .bio {
    padding: 72px 0;
    border-top: 1px solid var(--line-on-paper);
  }
  .bio-grid {
    display: grid;
    grid-template-columns: 320px 1fr;
    gap: 64px;
  }
  .portrait img {
    width: 100%;
    height: auto;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    background: var(--paper-2);
    border: 1px solid var(--line-on-paper);
    display: block;
  }
  .portrait-caption {
    margin-top: 16px;
  }
  .portrait-caption .eyebrow {
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 400;
    margin-bottom: 6px;
  }
  .portrait-caption .name {
    font-size: 20px;
    letter-spacing: -0.01em;
    font-weight: 300;
  }
  .portrait-caption .role {
    font-size: 12px;
    color: var(--mute-on-paper);
    margin-top: 4px;
    font-weight: 300;
  }

  .bio-text {
    max-width: 64ch;
  }
  .bio-text .lede {
    font-size: 22px;
    line-height: 1.4;
    font-weight: 300;
    color: var(--ink-on-paper);
    margin-bottom: 24px;
  }
  .bio-text h2 {
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--mute-on-paper-2);
    font-weight: 400;
    margin-top: 40px;
    margin-bottom: 12px;
  }
  .bio-text .muted {
    color: var(--mute-on-paper);
  }

  @media (max-width: 900px) {
    .bio-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .portrait img {
      max-width: 360px;
    }
  }

  /* cv stack */
  .block {
    padding: 80px 0;
    border-top: 1px solid var(--line-on-paper);
  }
  .block.alt {
    background: var(--paper-2);
  }
  .proof-head {
    margin-bottom: 48px;
  }
  .proof-head .eyebrow {
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 400;
    margin-bottom: 16px;
  }
  .block-h {
    font-size: clamp(26px, 3vw, 38px);
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin: 0;
    font-weight: 300;
    max-width: 24ch;
    text-wrap: balance;
  }
  .cv-stack {
    display: grid;
    gap: 0;
  }
  .cv-row {
    display: grid;
    grid-template-columns: 180px 280px 1fr;
    gap: 32px;
    align-items: baseline;
    padding: 22px 0;
    border-top: 1px solid var(--line-on-paper);
  }
  /* no border-bottom on last cv-row, the following .block adds its own border-top */
  .cv-period {
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--mute-on-paper-2);
    font-weight: 400;
  }
  .cv-role {
    font-size: 16px;
    font-weight: 400;
  }
  .cv-org {
    font-size: 12px;
    color: var(--mute-on-paper);
    margin-top: 4px;
    font-weight: 300;
  }
  .cv-body {
    font-size: 14px;
    line-height: 1.6;
    color: var(--mute-on-paper);
    font-weight: 300;
    max-width: 52ch;
  }
  @media (max-width: 900px) {
    .cv-row {
      grid-template-columns: 1fr;
      gap: 8px;
    }
  }

  .philosophy-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 32px;
  }
  .philosophy-grid > div .eyebrow {
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 400;
    margin-bottom: 10px;
  }
  .phil-h {
    font-size: 19px;
    font-weight: 400;
    margin: 0 0 8px;
  }
  .phil-body {
    font-size: 14px;
    line-height: 1.55;
    color: var(--mute-on-paper);
    font-weight: 300;
    margin: 0;
  }
  @media (max-width: 900px) {
    .philosophy-grid {
      grid-template-columns: 1fr 1fr;
      gap: 24px;
    }
  }
  @media (max-width: 540px) {
    .philosophy-grid {
      grid-template-columns: 1fr;
    }
  }

  .closing-cta {
    padding: 96px 0;
    border-top: 1px solid var(--line-on-paper);
  }
  .closing-inner {
    max-width: 800px;
  }
  .closing-h {
    font-size: clamp(28px, 3.5vw, 44px);
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin: 0 0 32px;
    font-weight: 300;
    text-wrap: balance;
  }
  .closing-ctas {
    display: flex;
    align-items: center;
    gap: 24px;
    flex-wrap: wrap;
  }
  .contact-line {
    font-size: 14px;
    color: var(--mute-on-paper);
    border-bottom: 1px solid transparent;
    padding: 4px 0;
  }
  .contact-line:hover {
    color: var(--amber);
    border-bottom-color: var(--amber);
  }
</style>
