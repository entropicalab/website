---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import { localized, tr } from '../../../i18n/utils';

const locale = 'en' as const;
const t = tr(locale);

export async function getStaticPaths() {
  const all = await getCollection('blog', ({ data }) => data.locale === 'en' && !data.draft);
  return all.map((entry) => ({
    params: { slug: entry.data.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { data } = entry;
const { Content } = await render(entry);

const fmt = new Intl.DateTimeFormat('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout
  title={`${data.title} · entrópica journal`}
  description={data.summary}
  locale={locale}
>
  <article class="post">
    <div class="site-wrap">
      <div class="crumb">
        <a href={localized('/blog', locale)}>{t('cta.back')} {t('nav.journal')}</a>
      </div>

      <header class="post-head">
        <div class="eyebrow amber">{data.eyebrow ?? '// the journal'}</div>
        <h1 class="post-h1">{data.title}</h1>
        <div class="post-byline">
          <time datetime={data.date.toISOString()}>{fmt.format(data.date)}</time>
          <span class="sep">·</span>
          <span>{data.author}</span>
        </div>
      </header>

      {data.heroImage && (
        <figure class="post-hero">
          <img src={data.heroImage} alt={data.title} loading="eager" />
        </figure>
      )}

      <div class="post-body prose">
        <Content />
      </div>

      <footer class="post-foot">
        <a class="btn" href={localized('/blog', locale)}>{t('cta.back')} {t('nav.journal')}</a>
      </footer>
    </div>
  </article>
</BaseLayout>

<style>
  .post { padding: 24px 0 96px; }

  .crumb {
    padding: 8px 0 48px;
    font-size: 11px;
    letter-spacing: 0.08em;
    color: var(--mute-on-paper);
  }
  .crumb a {
    color: var(--mute-on-paper);
    border-bottom: 1px solid transparent;
  }
  .crumb a:hover { color: var(--amber); border-bottom-color: var(--amber); }

  .post-head {
    max-width: 760px;
    margin-bottom: 56px;
  }
  .post-head .eyebrow {
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 400;
    margin-bottom: 20px;
    display: inline-block;
  }
  .post-h1 {
    font-size: clamp(32px, 5vw, 56px);
    line-height: 1.05;
    letter-spacing: -0.025em;
    margin: 0 0 24px;
    font-weight: 300;
    text-wrap: balance;
  }
  .post-byline {
    font-size: 12px;
    letter-spacing: 0.04em;
    color: var(--mute-on-paper);
    font-weight: 300;
    display: flex;
    gap: 12px;
    align-items: center;
  }
  .post-byline .sep { color: var(--mute-on-paper-2); }

  .post-hero {
    margin: 0 0 56px;
    padding: 0;
    width: 100%;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: var(--paper-2);
    border: 1px solid var(--line-on-paper);
  }
  .post-hero img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .post-body {
    max-width: 64ch;
  }

  /* h2 is a section divider with the brand's // eyebrow prefix */
  .post-body :global(h2) {
    font-size: 24px;
    font-weight: 400;
    letter-spacing: -0.01em;
    line-height: 1.25;
    margin: 64px 0 20px;
    padding-top: 32px;
    border-top: 1px solid var(--line-on-paper);
    color: var(--ink-on-paper);
  }
  .post-body :global(h2)::before {
    content: '// ';
    color: var(--mute-on-paper-2);
    font-weight: 400;
    margin-right: 2px;
  }

  /* h3 styled as a sub-eyebrow */
  .post-body :global(h3) {
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 500;
    color: var(--mute-on-paper-2);
    margin: 36px 0 12px;
  }

  /* body paragraphs */
  .post-body :global(p) {
    font-size: 17px;
    line-height: 1.75;
    font-weight: 400;
    margin: 0 0 18px;
    color: var(--ink-on-paper);
  }

  /* the opening blockquote, treat as a pull-quote / lede */
  .post-body :global(blockquote) {
    border-left: 2px solid var(--amber);
    padding: 4px 0 4px 20px;
    margin: 0 0 32px;
    font-size: 22px;
    line-height: 1.35;
    font-weight: 300;
    letter-spacing: -0.005em;
    color: var(--ink-on-paper);
    font-style: normal;
    max-width: 32ch;
  }
  .post-body :global(blockquote p) {
    font-size: inherit;
    line-height: inherit;
    font-weight: inherit;
    margin: 0;
  }

  /* lists */
  .post-body :global(ul), .post-body :global(ol) {
    font-size: 17px;
    line-height: 1.7;
    font-weight: 400;
    padding-left: 22px;
    margin: 0 0 18px;
  }
  .post-body :global(li) { margin-bottom: 6px; }
  .post-body :global(ul li)::marker { color: var(--amber); }

  /* emphasis */
  .post-body :global(strong), .post-body :global(b) {
    color: var(--ink-on-paper);
    font-weight: 500;
  }
  .post-body :global(em), .post-body :global(i) {
    font-style: normal;
    color: var(--mute-on-paper);
  }

  /* horizontal rule */
  .post-body :global(hr) {
    border: none;
    border-top: 1px solid var(--line-on-paper);
    margin: 64px 0 48px;
  }

  /* inline code */
  .post-body :global(code) {
    font-family: var(--font-mono);
    background: var(--paper-2);
    border: 1px solid var(--line-on-paper);
    padding: 1px 6px;
    font-size: 0.92em;
  }

  /* links */
  .post-body :global(a) {
    color: inherit;
    border-bottom: 1px solid var(--line-on-paper-2);
  }
  .post-body :global(a:hover) { color: var(--amber); border-bottom-color: var(--amber); }

  .post-foot {
    margin-top: 80px;
    padding-top: 32px;
    border-top: 1px solid var(--line-on-paper);
  }
</style>
