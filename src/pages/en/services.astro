---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { localized, tr } from '../../i18n/utils';

const locale = 'en' as const;
const t = tr(locale);

const services = [
  {
    n: '01',
    icon: 'architecture',
    title: 'concept design',
    short: 'the foundational service. this is where the decisions with the most leverage over a building\'s energy get made, before the section is committed.',
    body: 'the basic, required service and almost always the point of greatest energy leverage. we define the program around the sun and the elements of the site, and we set the energy goals along with their feasibility. orientation, footprint, and the big shading decisions are resolved with climate evidence, because the cheapest move in any building is the one that happens before the lines are drawn.',
    deliverables: ['climate-tuned massing studies', 'program defined around sun and site', 'energy goals + feasibility'],
  },
  {
    n: '02',
    icon: 'dashboard_customize',
    title: 'architectural design + coordination',
    short: 'the construction-documents phase: materials, assemblies, and systems, coordinated to meet or beat the energy goals.',
    body: 'the construction-drawings phase. materials, assemblies, and systems are decided here, and we hold coordination workshops with the structural, electrical, plumbing, and mechanical engineers so the project meets, or exceeds, the energy goals set at concept.',
    deliverables: ['construction documents + specifications', 'materials, assemblies, and systems', 'coordination workshops with engineering (structural, electrical, plumbing, mechanical)'],
  },
  {
    n: '03',
    icon: 'description',
    title: 'permitting + documentation',
    short: 'preliminary designs and drawings approved, backed by more than ten years of experience in the municipality of panamá and countrywide.',
    body: 'more than ten years approving preliminary designs (anteproyecto) and miscellaneous and construction drawings in the municipality of panamá and across the country. we write the documents the way they will be read, by the office processing the permit, and by the contractor estimating the build.',
    deliverables: ['anteproyecto for municipal review', 'miscellaneous + construction drawings', 'filing in the municipality of panamá and countrywide'],
  },
  {
    n: '04',
    icon: 'monitoring',
    title: 'energy + performance advisory',
    short: 'data-based answers to energy questions, for consultancy, certification, or already-built projects.',
    body: 'fits consultancy, certification, or already-built projects. we give data-based answers to concrete energy questions: whether to widen an opening for better ventilation, whether a more insulated façade pays for itself. we work hand in hand with product manufacturers, with architecture firms, and, among others, with a japanese urban-farm developer.',
    deliverables: ['envelope, daylight, and energy modelling (energy+, radiance, openfoam)', 'data-based answers to design questions', 'leed / edge documentation support'],
  },
];
---

<BaseLayout
  title="services · entrópica · architects in panamá"
  description="energy-led tropical and bioclimatic architecture services in panamá: concept design, documentation and coordination, permitting (jtia, mupa), and energy and performance advisory."
  locale={locale}
>
  <!-- hero -->
  <section class="hero">
    <div class="site-wrap">
      <div class="eyebrow">// services</div>
      <h1 class="hero-h">
        full architectural services,<br />
        energy-led.
      </h1>
      <p class="hero-lede">
        from concept to construction. energy and operational performance guide
        every design decision, not as a separate workstream, but as the same
        conversation the section is being drawn in.
      </p>
    </div>
  </section>

  <!-- services list -->
  <section class="services-section">
    <div class="site-wrap">
      <div class="services-list">
        {services.map((s) => (
          <article class="service-row">
            <div class="svc-n">
              <span class="material-symbols-outlined icon-md icon-amber svc-icon">{s.icon}</span>
              <span class="svc-num">{s.n}</span>
            </div>
            <div class="svc-title">{s.title}</div>
            <div class="svc-content">
              <p class="svc-short">{s.short}</p>
              <p class="svc-body">{s.body}</p>
              <div class="svc-deliverables">
                <div class="dv-eb">// deliverables</div>
                <ul>
                  {s.deliverables.map((d) => (
                    <li>{d}</li>
                  ))}
                </ul>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- architecture + interiors -->
  <section class="block">
    <div class="site-wrap">
      <div class="two-col">
        <div class="col-eb">
          <div class="eyebrow">// architecture + interiors</div>
        </div>
        <div class="col-body">
          <h2 class="block-h">new build or existing space.</h2>
          <div class="prose">
            <p>
              these services apply to architectural projects, where the envelope is still
              to be defined, and to interior-design projects, where the envelope is fixed
              and the work is rearranging spaces and systems to win thermal comfort with
              what is already there. our guide on
              <a class="inline-link" href={localized('/blog/sustainable-architecture-panama', locale)}>sustainable architecture in panamá</a>
              explains the envelope logic behind both.
            </p>
            <p>
              <a class="inline-link" href={localized('/projects/current-technologies', locale)}>current technologies</a>
              is an interiors example: same energy logic, different starting point.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- engagement model -->
  <section class="block alt">
    <div class="site-wrap">
      <div class="two-col">
        <div class="col-eb">
          <div class="eyebrow">// how we work</div>
        </div>
        <div class="col-body">
          <h2 class="block-h">engaged early, engaged small, engaged honestly.</h2>
          <div class="prose">
            <p>
              we prefer to be in the room from feasibility, the smaller the project,
              the earlier energy earns its keep. but we also pick up envelope and
              performance work mid-project, where the architecture is already set and
              the envelope still needs to be argued for.
            </p>
            <p>
              fees are scoped per project. retainers are available for repeat clients
              and developers with multiple sites in the pipeline. we don't take work
              whose performance we can't stand behind honestly, and we'll say so before
              the proposal lands.
            </p>
            <p>
              questions about scope, permitting, or certification?
              <a class="inline-link" href={localized('/faq', locale)}>frequently asked questions</a>.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- closing CTA -->
  <section class="closing-cta">
    <div class="site-wrap">
      <div class="closing-inner">
        <div class="eyebrow">// the next collaboration</div>
        <h2 class="closing-h">
          tell us about the climate and the brief.<br />
          we'll tell you what the building needs.
        </h2>
        <div class="closing-ctas">
          <a class="btn amber" href={localized('/contact', locale)}>
            {t('cta.contact')}
            <span class="arrow-tail" aria-hidden="true"></span>
          </a>
          <a class="contact-line" href="mailto:info@entropica-lab.com">info@entropica-lab.com</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding: 96px 0 64px;
  }
  .hero .eyebrow {
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin-bottom: 24px;
    font-weight: 400;
  }
  .hero-h {
    font-size: clamp(34px, 5vw, 60px);
    line-height: 1.05;
    letter-spacing: -0.025em;
    margin: 0 0 28px;
    font-weight: 300;
    max-width: 18ch;
    text-wrap: balance;
  }
  .hero-lede {
    font-size: clamp(17px, 1.4vw, 19px);
    line-height: 1.6;
    color: var(--mute-on-paper);
    max-width: 60ch;
    margin: 0;
    font-weight: 300;
  }

  .services-section {
    padding: 24px 0 80px;
  }
  .services-list {
    display: flex;
    flex-direction: column;
  }
  .service-row {
    display: grid;
    grid-template-columns: 80px 260px 1fr;
    gap: 48px;
    padding: 48px 0;
    border-top: 1px solid var(--line-on-paper);
    align-items: start;
  }
  .service-row:last-child {
    border-bottom: 1px solid var(--line-on-paper);
  }
  .svc-n {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 12px;
  }
  .svc-n .svc-num {
    font-size: 32px;
    color: var(--mute-on-paper-2);
    font-feature-settings: 'tnum' 1;
    letter-spacing: -0.02em;
    font-weight: 300;
    line-height: 1;
  }
  .svc-n .svc-icon {
    display: block;
  }
  .svc-title {
    font-size: 22px;
    line-height: 1.15;
    letter-spacing: -0.015em;
    font-weight: 300;
  }
  .svc-content {
    max-width: 56ch;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .svc-short {
    font-size: 17px;
    line-height: 1.5;
    color: var(--ink-on-paper);
    font-weight: 300;
    margin: 0;
  }
  .svc-body {
    font-size: 14px;
    line-height: 1.65;
    color: var(--mute-on-paper);
    font-weight: 300;
    margin: 0;
  }
  .svc-deliverables {
    margin-top: 8px;
  }
  .dv-eb {
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--mute-on-paper-2);
    font-weight: 400;
    margin-bottom: 8px;
  }
  .svc-deliverables ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
    font-size: 13px;
    color: var(--mute-on-paper);
    font-weight: 300;
  }
  .svc-deliverables li::before {
    content: '› ';
    color: var(--amber);
    margin-right: 4px;
  }

  @media (max-width: 900px) {
    .service-row {
      grid-template-columns: 1fr;
      gap: 12px;
    }
    .svc-n {
      font-size: 22px;
    }
  }

  .block {
    padding: 80px 0;
    border-top: 1px solid var(--line-on-paper);
  }
  .block.alt {
    background: var(--paper-2);
  }
  .proof-head {
    margin-bottom: 48px;
  }
  .proof-head .eyebrow {
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 400;
    margin-bottom: 16px;
  }
  .block-h {
    font-size: clamp(26px, 3vw, 38px);
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin: 0 0 24px;
    font-weight: 300;
    max-width: 26ch;
    text-wrap: balance;
  }

  .problems-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }
  .problem {
    padding: 24px 28px;
    background: var(--paper);
    border: 1px solid var(--line-on-paper);
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .prob-name {
    font-size: 16px;
    font-weight: 400;
    color: var(--ink-on-paper);
  }
  .prob-soln {
    font-size: 14px;
    color: var(--mute-on-paper);
    line-height: 1.6;
    font-weight: 300;
  }
  @media (max-width: 700px) {
    .problems-grid {
      grid-template-columns: 1fr;
    }
  }

  .two-col {
    display: grid;
    grid-template-columns: 240px 1fr;
    gap: 80px;
  }
  .col-eb .eyebrow {
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 400;
    padding-top: 4px;
  }
  @media (max-width: 900px) {
    .two-col {
      grid-template-columns: 1fr;
      gap: 24px;
    }
  }

  .closing-cta {
    padding: 96px 0;
    border-top: 1px solid var(--line-on-paper);
  }
  .closing-inner {
    max-width: 800px;
  }
  .closing-inner .eyebrow {
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin-bottom: 16px;
    font-weight: 400;
  }
  .closing-h {
    font-size: clamp(28px, 3.5vw, 44px);
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin: 0 0 32px;
    font-weight: 300;
    text-wrap: balance;
  }
  .closing-ctas {
    display: flex;
    align-items: center;
    gap: 24px;
    flex-wrap: wrap;
  }
  .contact-line {
    font-size: 14px;
    color: var(--mute-on-paper);
    border-bottom: 1px solid transparent;
    padding: 4px 0;
  }
  .contact-line:hover {
    color: var(--amber);
    border-bottom-color: var(--amber);
  }
</style>
