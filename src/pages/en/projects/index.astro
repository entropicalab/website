---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { localized } from '../../../i18n/utils';

const locale = 'en' as const;

const all = await getCollection('projects', ({ data }) => data.locale === locale);
const projects = all.sort((a, b) => {
  const ad = a.data.order ?? 99;
  const bd = b.data.order ?? 99;
  return ad - bd;
});
---

<BaseLayout
  title="work · entrópica · tropical architecture in panamá"
  description="selected projects from entrópica in panamá: residential, commercial, institutional, and mixed-use. tropical, bioclimatic architecture with energy as a design criterion from the start."
  locale={locale}
>
  <section class="hero">
    <div class="site-wrap">
      <div class="eyebrow">// the work</div>
      <h1 class="hero-h">selected projects.</h1>
      <p class="hero-lede">
        a curated selection of the work we have been paid to design. residential,
        commercial, institutional. in panamá and beyond. what they share is climate
        as the first design move.
      </p>
    </div>
  </section>

  <section class="projects-section">
    <div class="site-wrap">
      <div class="projects-grid">
        {projects.map((p) => {
          const cs = p.data.comingSoon;
          const inner = (
            <>
              <div class="pcard-photo">
                {p.data.heroImage ? (
                  <img src={p.data.heroImage} alt={p.data.title} loading="lazy" />
                ) : (
                  <span class="ph-tag">{p.data.eyebrow ?? '// image'}</span>
                )}
                {cs && <span class="cs-badge">coming soon</span>}
              </div>
              <div class="pcard-meta">
                <div class="pcard-eb">{p.data.eyebrow}</div>
                <h2 class="pcard-title">{p.data.title}</h2>
                <div class="pcard-loc">{p.data.location}</div>
              </div>
            </>
          );
          return cs ? (
            <div class="pcard pcard--soon">{inner}</div>
          ) : (
            <a class="pcard" href={localized(`/projects/${p.data.slug}`, locale)}>{inner}</a>
          );
        })}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero { padding: 96px 0 64px; }
  .hero .eyebrow { font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; margin-bottom: 24px; font-weight: 400; }
  .hero-h { font-size: clamp(34px, 5vw, 60px); line-height: 1.05; letter-spacing: -0.025em; margin: 0 0 28px; font-weight: 300; max-width: 24ch; text-wrap: balance; }
  .hero-lede { font-size: clamp(17px, 1.4vw, 19px); line-height: 1.6; color: var(--mute-on-paper); max-width: 60ch; margin: 0; font-weight: 300; }

  .projects-section { padding: 24px 0 96px; }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .pcard {
    display: flex;
    flex-direction: column;
    color: inherit;
    text-decoration: none;
    border: 1px solid var(--line-on-paper);
    transition: border-color 0.15s;
  }
  .pcard:hover { border-color: var(--mute-on-paper); }
  .pcard--soon { opacity: 0.5; cursor: default; }

  .pcard-photo {
    aspect-ratio: 4 / 3;
    background: var(--paper-2);
    background-image: repeating-linear-gradient(135deg, rgba(0,0,0,0.03) 0 12px, transparent 12px 24px);
    position: relative;
    overflow: hidden;
    flex-shrink: 0;
  }
  .pcard-photo img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s;
  }
  .pcard:not(.pcard--soon):hover .pcard-photo img { transform: scale(1.03); }
  .pcard-photo .ph-tag {
    position: absolute;
    top: 14px;
    left: 16px;
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--mute-on-paper-2);
    font-weight: 400;
  }
  .cs-badge {
    position: absolute;
    bottom: 12px;
    left: 14px;
    font-size: 9px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-on-paper);
    background: var(--paper);
    border: 1px solid var(--line-on-paper);
    padding: 4px 8px;
    font-weight: 400;
  }

  .pcard-meta {
    padding: 16px 18px 20px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .pcard-eb { font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--mute-on-paper-2); font-weight: 400; }
  .pcard-title { font-size: 18px; line-height: 1.15; letter-spacing: -0.01em; font-weight: 300; margin: 0; }
  .pcard-loc { font-size: 12px; color: var(--mute-on-paper); font-weight: 400; }

  @media (max-width: 900px) { .projects-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 540px) { .projects-grid { grid-template-columns: 1fr; } }
</style>
