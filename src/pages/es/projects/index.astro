---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { localized } from '../../../i18n/utils';

const locale = 'es' as const;

const all = await getCollection('projects', ({ data }) => data.locale === locale);
const projects = all.sort((a, b) => {
  const ad = a.data.order ?? 99;
  const bd = b.data.order ?? 99;
  return ad - bd;
});
---

<BaseLayout
  title="proyectos · entrópica"
  description="estudios de caso seleccionados, cada uno un edificio moldeado por su clima. arquitectura tropical validada por simulación."
  locale={locale}
>
  <section class="hero">
    <div class="site-wrap">
      <div class="eyebrow">// el trabajo</div>
      <h1 class="hero-h">proyectos seleccionados.</h1>
      <p class="hero-lede">
        cada proyecto a continuación está construido alrededor de un solo número:
        el que produjo el modelo y que el edificio tuvo que ganarse. el resto del
        estudio explica cómo llegó hasta ahí la sección.
      </p>
    </div>
  </section>

  <section class="projects-section">
    <div class="site-wrap">
      <div class="projects-grid">
        {projects.map((p, i) => (
          <a class={`pcard ${i === 0 ? 'lead' : ''}`} href={localized(`/projects/${p.data.slug}`, locale)}>
            <div class="pcard-photo">
              {p.data.heroImage ? (
                <img src={p.data.heroImage} alt={p.data.title} loading="lazy" />
              ) : (
                <span class="ph-tag">{p.data.gallery?.[0]?.tag ?? '// 16∶9 · hero'}</span>
              )}
            </div>
            <div class="pcard-meta">
              <div class="pcard-eb">{p.data.eyebrow}</div>
              <h2 class="pcard-title">{p.data.title}</h2>
              <p class="pcard-lede">{p.data.lede}</p>
              <div class="pcard-info">
                <div><span class="k">ubicación</span><span class="v">{p.data.location}</span></div>
                <div><span class="k">año</span><span class="v">{p.data.year}</span></div>
                <div><span class="k">área</span><span class="v">{p.data.area}</span></div>
                <div><span class="k">tipología</span><span class="v">{p.data.typology}</span></div>
              </div>
              <div class="pcard-metric">
                <span class="num">{p.data.metric.value}<span class="unit">{p.data.metric.unit}</span></span>
                <span class="ml">{p.data.metric.label}</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero { padding: 96px 0 64px; }
  .hero .eyebrow { font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; margin-bottom: 24px; font-weight: 400; }
  .hero-h { font-size: clamp(34px, 5vw, 60px); line-height: 1.05; letter-spacing: -0.025em; margin: 0 0 28px; font-weight: 300; max-width: 24ch; text-wrap: balance; }
  .hero-lede { font-size: clamp(17px, 1.4vw, 19px); line-height: 1.6; color: var(--mute-on-paper); max-width: 60ch; margin: 0; font-weight: 300; }

  .projects-section { padding: 24px 0 96px; }
  .projects-grid { display: grid; grid-template-columns: 1fr; gap: 0; }
  .pcard { display: grid; grid-template-columns: 1.1fr 1fr; gap: 48px; padding: 48px 0; border-top: 1px solid var(--line-on-paper); color: inherit; text-decoration: none; align-items: start; transition: background 0.15s; }
  .pcard:hover { background: var(--paper-2); }
  .pcard:last-child { border-bottom: 1px solid var(--line-on-paper); }
  .pcard-photo { aspect-ratio: 16 / 10; background: var(--paper-2); background-image: repeating-linear-gradient(135deg, rgba(0, 0, 0, 0.03) 0 12px, transparent 12px 24px); border: 1px solid var(--line-on-paper); position: relative; overflow: hidden; }
  .pcard-photo img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; display: block; }
  .pcard.lead .pcard-photo { aspect-ratio: 16 / 11; }
  .pcard:hover .pcard-photo { border-color: var(--mute-on-paper); }
  .pcard-photo .ph-tag { position: absolute; top: 14px; left: 16px; font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--mute-on-paper-2); font-weight: 400; }
  .pcard-meta { display: flex; flex-direction: column; gap: 14px; padding-top: 8px; }
  .pcard-eb { font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--mute-on-paper-2); font-weight: 400; }
  .pcard-title { font-size: 28px; line-height: 1.1; letter-spacing: -0.02em; font-weight: 300; margin: 0; }
  .pcard.lead .pcard-title { font-size: 36px; }
  .pcard-lede { font-size: 15px; line-height: 1.55; color: var(--mute-on-paper); font-weight: 300; margin: 0; max-width: 50ch; }
  .pcard-info { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px 16px; margin-top: 8px; }
  .pcard-info > div { display: flex; flex-direction: column; gap: 2px; }
  .pcard-info .k { font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--mute-on-paper-2); font-weight: 400; }
  .pcard-info .v { font-size: 13px; font-weight: 300; }
  .pcard-metric { display: flex; align-items: baseline; gap: 14px; padding-top: 16px; margin-top: 8px; border-top: 1px solid var(--line-on-paper); }
  .pcard-metric .num { font-size: 28px; color: var(--ink-on-paper); font-feature-settings: 'tnum' 1, 'lnum' 1; letter-spacing: -0.02em; line-height: 1; font-weight: 300; }
  .pcard:hover .pcard-metric .num { color: var(--amber); }
  .pcard-metric .num .unit { font-size: 0.5em; vertical-align: top; margin-left: 1px; }
  .pcard-metric .ml { font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--mute-on-paper); font-weight: 400; }
  @media (max-width: 900px) { .pcard { grid-template-columns: 1fr; gap: 20px; } .pcard-info { grid-template-columns: repeat(2, 1fr); } }
</style>
