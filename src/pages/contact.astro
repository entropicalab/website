---
import BaseLayout from '../layouts/BaseLayout.astro';
import { tr } from '../i18n/utils';

const locale = 'es' as const;
const t = tr(locale);

const FORMSPREE_ENDPOINT = 'https://formspree.io/f/xkoerobb';

const typologies = [
  { v: '', l: t('form.typology.placeholder') },
  { v: 'residencial', l: t('typology.residential') },
  { v: 'comercial', l: t('typology.commercial') },
  { v: 'institucional', l: t('typology.institutional') },
  { v: 'uso mixto', l: t('typology.mixedUse') },
  { v: 'otro', l: 'otro' },
];

const sent = Astro.url.searchParams.get('sent') === '1';
---

<BaseLayout
  title="contacto · entrópica · estudio de arquitectura en panamá"
  description="escríbenos, y hagamos edificios frescos en lugares calurosos. ph plaza mar, paitilla, ciudad de panamá. info@entropica-lab.com · +507 6944-4740."
  locale={locale}
>
  <section class="contact-hero">
    <div class="site-wrap">
      <div class="eyebrow">// 2026 ▸ aceptamos nuevos proyectos</div>
      <h1 class="hero-h">
        escríbenos y hagamos edificios<br />
        de menor impacto y menores costos.
      </h1>
      <p class="hero-lede">
        cuéntanos del proyecto y del clima. solemos responder en dos días hábiles.
        para prensa, charlas o preguntas generales, el correo es el camino más rápido.
      </p>
    </div>
  </section>

  <section class="contact-body">
    <div class="site-wrap">
      <div class="contact-grid">
        <div class="form-col">
          {sent ? (
            <div class="sent">
              <div class="eyebrow amber">// mensaje recibido</div>
              <h2>{t('form.sent.title')}</h2>
              <p>{t('form.sent.body')}</p>
              <a class="btn" href="/es">← inicio</a>
            </div>
          ) : (
            <form class="contact-form" action={FORMSPREE_ENDPOINT} method="POST">
              <div class="field">
                <label for="name">{t('form.name')}</label>
                <input id="name" name="name" type="text" required autocomplete="name" />
              </div>

              <div class="field">
                <label for="email">{t('form.email')}</label>
                <input id="email" name="email" type="email" required autocomplete="email" />
              </div>

              <div class="field">
                <label for="company">{t('form.company')}</label>
                <input id="company" name="company" type="text" autocomplete="organization" />
              </div>

              <div class="field">
                <label for="location">{t('form.location')}</label>
                <input id="location" name="location" type="text" placeholder="ciudad, país" />
              </div>

              <div class="field full">
                <label for="typology">{t('form.typology')}</label>
                <select id="typology" name="typology">
                  {typologies.map((tp) => (
                    <option value={tp.v} disabled={tp.v === ''}>{tp.l}</option>
                  ))}
                </select>
              </div>

              <div class="field full">
                <label for="brief">{t('form.brief')}</label>
                <textarea id="brief" name="brief" rows="6" required></textarea>
              </div>

              <input type="hidden" name="_subject" value="entropica-lab.com · nuevo mensaje del formulario" />
              <input type="hidden" name="_next" value="/es/contact?sent=1" />

              <div class="honeypot" aria-hidden="true">
                <label>no llenes este campo</label>
                <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" />
              </div>

              <div class="actions">
                <button type="submit" class="btn amber">
                  {t('form.send')}
                  <span class="arrow-tail" aria-hidden="true"></span>
                </button>
              </div>
            </form>
          )}
        </div>

        <aside class="info-col">
          <div class="info-block">
            <div class="eyebrow">// estudio</div>
            <p>
              entrópica<br />
              ph plaza mar · paitilla<br />
              ciudad de panamá · panamá, centroamérica<br />
              <span class="muted">watts &amp; matter consulting, s. e.p.</span>
            </p>
          </div>

          <div class="info-block">
            <div class="eyebrow">// directo</div>
            <ul>
              <li><a class="info-link" href="mailto:info@entropica-lab.com">info@entropica-lab.com</a></li>
              <li><a class="info-link" href="https://wa.me/50769444740" target="_blank" rel="noopener">whatsapp · +507 6944-4740</a></li>
              <li><a class="info-link" href="https://instagram.com/entropicalab" target="_blank" rel="noopener">@entropicalab</a></li>
            </ul>
          </div>

          <div class="info-block">
            <div class="eyebrow">// horario</div>
            <p class="muted">
              lunes, viernes<br />
              09:00, 18:00 est (utc -5)
            </p>
          </div>

          <div class="info-block">
            <div class="eyebrow">// prensa</div>
            <p class="muted">
              imágenes en alta resolución y datos de proyecto disponibles bajo solicitud.<br />
              escribe a <a class="info-link" href="mailto:info@entropica-lab.com">info@entropica-lab.com</a> con "prensa" en el asunto.
            </p>
          </div>
        </aside>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-hero { padding: 96px 0 56px; }
  .contact-hero .eyebrow { font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; margin-bottom: 24px; font-weight: 400; }
  .hero-h { font-size: clamp(32px, 4.5vw, 56px); line-height: 1.05; letter-spacing: -0.025em; margin: 0 0 28px; font-weight: 300; text-wrap: balance; }
  .hero-lede { font-size: clamp(16px, 1.4vw, 19px); line-height: 1.6; color: var(--mute-on-paper); max-width: 60ch; margin: 0; font-weight: 300; }

  .contact-body { padding: 24px 0 96px; }
  .contact-grid { display: grid; grid-template-columns: 1.6fr 1fr; gap: 80px; }
  @media (max-width: 900px) { .contact-grid { grid-template-columns: 1fr; gap: 48px; } }

  .form-col { max-width: 640px; }
  .sent { padding: 32px; border: 1px solid var(--line-on-paper); background: var(--paper-2); }
  .sent .eyebrow { font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; font-weight: 400; margin-bottom: 16px; display: inline-block; }
  .sent h2 { font-size: 26px; font-weight: 300; letter-spacing: -0.015em; margin: 0 0 12px; }
  .sent p { font-size: 16px; color: var(--mute-on-paper); font-weight: 300; margin: 0 0 24px; line-height: 1.6; }

  .info-col { display: flex; flex-direction: column; gap: 32px; padding-top: 12px; }
  .info-block .eyebrow { font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--mute-on-paper-2); font-weight: 400; margin-bottom: 10px; display: inline-block; }
  .info-block p { font-size: 14px; line-height: 1.65; font-weight: 300; margin: 0; }
  .info-block .muted { color: var(--mute-on-paper); }
  .info-block ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 4px; font-size: 14px; font-weight: 300; }
  .info-link { color: var(--ink-on-paper); border-bottom: 1px solid var(--line-on-paper-2); }
  .info-link:hover { color: var(--amber); border-bottom-color: var(--amber); }
</style>
