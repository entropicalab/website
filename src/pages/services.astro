---
import BaseLayout from '../layouts/BaseLayout.astro';
import { localized, tr } from '../i18n/utils';

const locale = 'es' as const;
const t = tr(locale);

const services = [
  {
    n: '01',
    icon: 'architecture',
    title: 'diseño conceptual',
    short: 'el servicio base. aquí se toman las decisiones que más mueven la energía del edificio, antes de comprometer la sección.',
    body: 'es el servicio fundamental y, casi siempre, el de mayor apalancamiento energético. definimos el programa en función del sol y de los elementos del sitio, y fijamos las metas de energía junto con su factibilidad. la orientación, la huella y las grandes decisiones de sombra se resuelven con evidencia climática, porque el movimiento más barato de un edificio es el que ocurre antes de trazar las líneas.',
    deliverables: ['estudios de masa ajustados al clima', 'programa definido según sol y sitio', 'metas de energía + factibilidad'],
  },
  {
    n: '02',
    icon: 'dashboard_customize',
    title: 'diseño + coordinación arquitectónica',
    short: 'la fase de documentación constructiva: materiales, ensamblajes y sistemas, coordinados para cumplir o superar las metas de energía.',
    body: 'la fase de planos constructivos. aquí se deciden materiales, ensamblajes y sistemas, y se sostienen talleres de coordinación con los ingenieros estructural, eléctrico, sanitario y mecánico, para que el proyecto cumpla, o supere, las metas de energía fijadas en el concepto.',
    deliverables: ['documentos constructivos + especificaciones', 'definición de materiales, ensamblajes y sistemas', 'talleres de coordinación con ingeniería (estructural, eléctrica, sanitaria, mecánica)'],
  },
  {
    n: '03',
    icon: 'description',
    title: 'permisos + documentación',
    short: 'anteproyectos y planos aprobados, con más de diez años de experiencia en el municipio de panamá y a nivel nacional.',
    body: 'más de diez años aprobando anteproyectos y planos misceláneos y constructivos en el municipio de panamá y en el resto del país. escribimos los documentos como serán leídos: por la oficina que procesa el permiso, y por el contratista que cotiza la obra.',
    deliverables: ['anteproyecto para revisión municipal', 'planos misceláneos + constructivos', 'tramitación en el municipio de panamá y a nivel nacional'],
  },
  {
    n: '04',
    icon: 'monitoring',
    title: 'asesoría en energía y desempeño',
    short: 'respuestas basadas en datos a preguntas de energía, para consultoría, certificación o proyectos ya construidos.',
    body: 'encaja en proyectos de consultoría, de certificación o ya construidos. damos respuestas basadas en datos a preguntas concretas de energía: si conviene ampliar un vano para ventilar mejor, si una fachada más aislada se paga sola. trabajamos de la mano con fabricantes de productos, con firmas de arquitectura y, entre otros, con un desarrollador japonés de agricultura urbana.',
    deliverables: ['modelación de envolvente, luz natural y energía (energy+, radiance, openfoam)', 'respuestas basadas en datos a preguntas de diseño', 'soporte documental leed / edge'],
  },
];
---

<BaseLayout
  title="servicios · entrópica · arquitectos en panamá"
  description="servicios de arquitectura tropical y bioclimática en panamá, guiados por energía: diseño conceptual, documentación y coordinación, permisos (jtia, mupa) y asesoría en energía y desempeño."
  locale={locale}
>
  <section class="hero">
    <div class="site-wrap">
      <div class="eyebrow">// servicios</div>
      <h1 class="hero-h">
        servicios arquitectónicos completos,<br />
        guiados por energía.
      </h1>
      <p class="hero-lede">
        desde el concepto hasta la construcción. el desempeño energético y operativo
        guían cada decisión de diseño, no como una línea de trabajo aparte, sino dentro
        de la misma conversación en la que se dibuja la sección.
      </p>
    </div>
  </section>

  <section class="services-section">
    <div class="site-wrap">
      <div class="services-list">
        {services.map((s) => (
          <article class="service-row">
            <div class="svc-n">
              <span class="material-symbols-outlined icon-md icon-amber svc-icon">{s.icon}</span>
              <span class="svc-num">{s.n}</span>
            </div>
            <div class="svc-title">{s.title}</div>
            <div class="svc-content">
              <p class="svc-short">{s.short}</p>
              <p class="svc-body">{s.body}</p>
              <div class="svc-deliverables">
                <div class="dv-eb">// entregables</div>
                <ul>{s.deliverables.map((d) => <li>{d}</li>)}</ul>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="block">
    <div class="site-wrap">
      <div class="two-col">
        <div class="col-eb"><div class="eyebrow">// arquitectura e interiores</div></div>
        <div class="col-body">
          <h2 class="block-h">obra nueva o espacio existente.</h2>
          <div class="prose">
            <p>
              estos servicios aplican tanto a proyectos de arquitectura, donde la
              envolvente aún está por definir, como a proyectos de diseño de interiores,
              donde la envolvente ya está fija y el trabajo es reorganizar espacios y
              sistemas para ganar confort térmico con lo que hay. nuestra guía sobre
              <a class="inline-link" href={localized('/blog/sustainable-architecture-panama', locale)}>arquitectura sostenible en panamá</a>
              explica la lógica de envolvente detrás de ambos.
            </p>
            <p>
              <a class="inline-link" href={localized('/projects/current-technologies', locale)}>current technologies</a>
              es un ejemplo de interiores: misma lógica de energía, distinto punto de
              partida.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="block alt">
    <div class="site-wrap">
      <div class="two-col">
        <div class="col-eb"><div class="eyebrow">// cómo trabajamos</div></div>
        <div class="col-body">
          <h2 class="block-h">temprano, pequeño y honesto.</h2>
          <div class="prose">
            <p>
              preferimos estar en la mesa desde la factibilidad, mientras más pequeño el
              proyecto, más temprano la energía se gana su lugar. pero también tomamos
              trabajos de envolvente y desempeño a media obra, donde la arquitectura ya
              está fijada y la envolvente aún necesita defenderse.
            </p>
            <p>
              los honorarios se cotizan por proyecto. tenemos retainers disponibles para
              clientes recurrentes y desarrolladores con varios proyectos en cartera. no
              tomamos trabajos cuyo desempeño no podamos sustentar con honestidad, y lo
              decimos antes de mandar la propuesta.
            </p>
            <p>
              ¿dudas sobre alcance, permisos o certificación?
              <a class="inline-link" href={localized('/faq', locale)}>preguntas frecuentes</a>.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="closing-cta">
    <div class="site-wrap">
      <div class="closing-inner">
        <div class="eyebrow">// la próxima colaboración</div>
        <h2 class="closing-h">
          cuéntanos del clima y del brief.<br />
          nosotros te decimos qué pide el edificio.
        </h2>
        <div class="closing-ctas">
          <a class="btn amber" href={localized('/contact', locale)}>
            {t('cta.contact')}
            <span class="arrow-tail" aria-hidden="true"></span>
          </a>
          <a class="contact-line" href="mailto:info@entropica-lab.com">info@entropica-lab.com</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero { padding: 96px 0 64px; }
  .hero .eyebrow { font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; margin-bottom: 24px; font-weight: 400; }
  .hero-h { font-size: clamp(34px, 5vw, 60px); line-height: 1.05; letter-spacing: -0.025em; margin: 0 0 28px; font-weight: 300; max-width: 22ch; text-wrap: balance; }
  .hero-lede { font-size: clamp(17px, 1.4vw, 19px); line-height: 1.6; color: var(--mute-on-paper); max-width: 60ch; margin: 0; font-weight: 300; }

  .services-section { padding: 24px 0 80px; }
  .services-list { display: flex; flex-direction: column; }
  .service-row { display: grid; grid-template-columns: 80px 260px 1fr; gap: 48px; padding: 48px 0; border-top: 1px solid var(--line-on-paper); align-items: start; }
  .service-row:last-child { border-bottom: 1px solid var(--line-on-paper); }
  .svc-n { display: flex; flex-direction: column; align-items: flex-start; gap: 12px; }
  .svc-n .svc-num { font-size: 32px; color: var(--mute-on-paper-2); font-feature-settings: 'tnum' 1; letter-spacing: -0.02em; font-weight: 300; line-height: 1; }
  .svc-n .svc-icon { display: block; }
  .svc-title { font-size: 22px; line-height: 1.15; letter-spacing: -0.015em; font-weight: 300; }
  .svc-content { max-width: 56ch; display: flex; flex-direction: column; gap: 16px; }
  .svc-short { font-size: 17px; line-height: 1.5; color: var(--ink-on-paper); font-weight: 300; margin: 0; }
  .svc-body { font-size: 14px; line-height: 1.65; color: var(--mute-on-paper); font-weight: 300; margin: 0; }
  .svc-deliverables { margin-top: 8px; }
  .dv-eb { font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--mute-on-paper-2); font-weight: 400; margin-bottom: 8px; }
  .svc-deliverables ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 4px; font-size: 13px; color: var(--mute-on-paper); font-weight: 300; }
  .svc-deliverables li::before { content: '› '; color: var(--amber); margin-right: 4px; }
  @media (max-width: 900px) { .service-row { grid-template-columns: 1fr; gap: 12px; } .svc-n { font-size: 22px; } }

  .block { padding: 80px 0; border-top: 1px solid var(--line-on-paper); }
  .block.alt { background: var(--paper-2); }
  .proof-head { margin-bottom: 48px; }
  .proof-head .eyebrow { font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; font-weight: 400; margin-bottom: 16px; }
  .block-h { font-size: clamp(26px, 3vw, 38px); line-height: 1.15; letter-spacing: -0.02em; margin: 0 0 24px; font-weight: 300; max-width: 26ch; text-wrap: balance; }
  .problems-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 24px; }
  .problem { padding: 24px 28px; background: var(--paper); border: 1px solid var(--line-on-paper); display: flex; flex-direction: column; gap: 8px; }
  .prob-name { font-size: 16px; font-weight: 400; color: var(--ink-on-paper); }
  .prob-soln { font-size: 14px; color: var(--mute-on-paper); line-height: 1.6; font-weight: 300; }
  @media (max-width: 700px) { .problems-grid { grid-template-columns: 1fr; } }

  .two-col { display: grid; grid-template-columns: 240px 1fr; gap: 80px; }
  .col-eb .eyebrow { font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; font-weight: 400; padding-top: 4px; }
  @media (max-width: 900px) { .two-col { grid-template-columns: 1fr; gap: 24px; } }

  .closing-cta { padding: 96px 0; border-top: 1px solid var(--line-on-paper); }
  .closing-inner { max-width: 800px; }
  .closing-inner .eyebrow { font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; margin-bottom: 16px; font-weight: 400; }
  .closing-h { font-size: clamp(28px, 3.5vw, 44px); line-height: 1.15; letter-spacing: -0.02em; margin: 0 0 32px; font-weight: 300; text-wrap: balance; }
  .closing-ctas { display: flex; align-items: center; gap: 24px; flex-wrap: wrap; }
  .contact-line { font-size: 14px; color: var(--mute-on-paper); border-bottom: 1px solid transparent; padding: 4px 0; }
  .contact-line:hover { color: var(--amber); border-bottom-color: var(--amber); }
</style>
