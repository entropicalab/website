---
import BaseLayout from '../layouts/BaseLayout.astro';
import { localized, tr } from '../i18n/utils';

const locale = 'es' as const;
const t = tr(locale);

const work = [
  { role: 'socio', org: 'trimpacta', period: '2024-presente', body: 'consultoría de sostenibilidad basada en datos para empresas y corporaciones. reportes de sostenibilidad, huella hídrica y contabilidad de carbono.' },
  { role: 'fundador', org: 'entrópica', period: '2020-presente', body: 'estudio de diseño centrado en energía. simulaciones de desempeño (energy+, openfoam, radiance), optimización de fachada, modelado de luz natural. clientes: desarrolladores, ongs y firmas multinacionales.' },
  { role: 'co-fundador', org: 'acta sustainable innovation zone', period: '2018-2021', body: 'lideró estrategias de planificación sostenible; coordinó y diseñó proyectos de recuperación de espacio público; promovió políticas urbanas orientadas a la sostenibilidad.' },
  { role: 'arquitecto junior', org: 'erdy mchenry architecture · philadelphia, pa', period: '2017-2018', body: 'desarrollo de diseño y análisis ambiental para proyectos institucionales y de uso mixto, incluyendo el edificio neptune de vanguard campus west ($76mm).' },
  { role: 'co-fundador · director de diseño', org: 'pentagrama', period: '2013-2015 · 2018-2023', body: 'dirigió proyectos arquitectónicos premiados (residenciales, comerciales, institucionales). manejó entrega de diseño, coordinación de consultores y supervisión de obra.' },
  { role: 'investigador', org: 'panamá green building council', period: '2013', body: 'benchmarking de sostenibilidad, investigación de políticas y adopción temprana de herramientas de simulación en panamá.' },
];

const honors = [
  { year: '2024', name: 'dna · design awards paris', detail: 'ganador, arquitectura cultural' },
  { year: '2023', name: 'moa panamá', detail: 'mención honorífica' },
];

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'josé barría',
  url: 'https://entropica-lab.com/about',
  jobTitle: 'arquitecto · fundador',
  worksFor: { '@type': 'Organization', name: 'entrópica', url: 'https://entropica-lab.com' },
  alumniOf: [
    { '@type': 'CollegeOrUniversity', name: 'university of pennsylvania' },
    { '@type': 'CollegeOrUniversity', name: 'isthmus', address: { '@type': 'PostalAddress', addressCountry: 'PA' } },
  ],
  knowsAbout: ['arquitectura tropical', 'simulación energética', 'diseño bioclimático', 'panamá'],
};
---

<BaseLayout
  title="nosotros · entrópica · arquitecto idóneo en panamá"
  description="entrópica es el trabajo de josé barría, arquitecto idóneo (jtia) y máster en environmental building design (upenn). arquitectura tropical y bioclimática en panamá, enfocada en la energía."
  locale={locale}
>
  <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
  <section class="hero">
    <div class="site-wrap">
      <div class="eyebrow">// nosotros</div>
      <h1 class="hero-h">
        en algún lugar entre el estudio<br />
        y el laboratorio.
      </h1>
      <p class="hero-lede">
        entrópica es el trabajo de josé barría, arquitecto registrado en panamá con un
        máster en environmental building design de la universidad de pensilvania.
        existimos entre el estudio de diseño y el laboratorio, buscando la manera
        sensata de diseñar en un clima que cambia. usamos simulación energética como
        herramienta desde el primer dibujo.
      </p>
    </div>
  </section>

  <section class="bio">
    <div class="site-wrap">
      <div class="bio-grid">
        <div class="portrait">
          <img src="/jose.png" alt="josé barría" />
          <div class="portrait-caption">
            <div class="eyebrow">// dirección</div>
            <div class="name">josé barría</div>
            <div class="role">fundador · arquitecto · simulación</div>
          </div>
        </div>
        <div class="bio-text prose">
          <p class="lede">
            josé es arquitecto registrado y fundador de entrópica.
          </p>
          <p>
            su experiencia abarca panamá y los estados unidos, en proyectos residenciales,
            comerciales e institucionales, siempre con un foco en diseño responsivo al
            clima y desempeño edilicio. ha trabajado en estudios en philadelphia y
            panamá, investigó en el panamá green building council, y co-fundó una
            práctica temprana de diseño sostenible que sentó la base técnica para
            entrópica.
          </p>
          <p>
            fuera de entrópica es socio de trimpacta, una consultora de sostenibilidad
            que aborda el lado corporativo del mismo problema, huella hídrica,
            contabilidad de carbono, y reportes para empresas que quieren el trabajo
            hecho honestamente.
          </p>

          <h2>educación</h2>
          <ul>
            <li><b>máster en environmental building design</b>, universidad de pensilvania (2017)</li>
            <li><b>licenciatura en arquitectura</b>, isthmus, panamá (2014)</li>
          </ul>

          <h2>distinciones</h2>
          <ul>
            {honors.map((h) => (
              <li><b>{h.name}</b>, {h.detail} <span class="muted">({h.year})</span></li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="block">
    <div class="site-wrap">
      <div class="proof-head">
        <div class="eyebrow">// el trabajo, antes de este trabajo</div>
        <h2 class="block-h">experiencia seleccionada.</h2>
      </div>

      <div class="cv-stack">
        {work.map((w) => (
          <article class="cv-row">
            <div class="cv-period">{w.period}</div>
            <div class="cv-meta">
              <div class="cv-role">{w.role}</div>
              <div class="cv-org">{w.org}</div>
            </div>
            <div class="cv-body">{w.body}</div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="block">
    <div class="site-wrap">
      <div class="two-col">
        <div class="col-eb"><div class="eyebrow">// ¿por qué tanta lluvia?</div></div>
        <div class="col-body">
          <h2 class="block-h">porque el clima es donde empieza el edificio.</h2>
          <div class="prose">
            <p>
              presentamos nuestros proyectos en condiciones lluviosas o nubladas a
              propósito. es un recordatorio de que el clima es el punto de partida, no un
              telón de fondo. el desempeño empieza por entender las realidades ambientales
              que el edificio va a enfrentar: clima, luz y cambio estacional moldean el
              confort, el uso energético y la resiliencia de largo plazo.
            </p>
            <p>
              al mostrar nuestros diseños en su verdadero contexto climático, hacemos un
              punto único: belleza y eficiencia son inseparables del lugar. nuestra guía sobre
              <a class="inline-link" href={localized('/blog/sustainable-architecture-panama', locale)}>arquitectura sostenible en panamá</a>
              desarrolla por qué esto importa en el trópico.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="block alt">
    <div class="site-wrap">
      <div class="philosophy-grid">
        <div>
          <div class="eyebrow">// principio 01</div>
          <h3 class="phil-h">primero pasivo.</h3>
          <p class="phil-body">orientación, sombra, aislamiento, vidrio, optimizados antes de dimensionar cualquier sistema.</p>
        </div>
        <div>
          <div class="eyebrow">// principio 02</div>
          <h3 class="phil-h">simular antes de dibujar.</h3>
          <p class="phil-body">modelos pequeños, hechos temprano, le ganan a un modelo grande hecho al final.</p>
        </div>
        <div>
          <div class="eyebrow">// principio 03</div>
          <h3 class="phil-h">medir el movimiento.</h3>
          <p class="phil-body">cada afirmación tiene un número detrás, en las mismas unidades en que el cliente paga.</p>
        </div>
        <div>
          <div class="eyebrow">// principio 04</div>
          <h3 class="phil-h">ser específico.</h3>
          <p class="phil-body">tropical significa tropical. los estándares importados no sobreviven el contacto con panamá.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="closing-cta">
    <div class="site-wrap">
      <div class="closing-inner">
        <h2 class="closing-h">
          si esto se parece al proyecto que tienes en mente,<br />
          deberíamos hablar.
        </h2>
        <div class="closing-ctas">
          <a class="btn amber" href={localized('/contact', locale)}>
            {t('cta.contact')}
            <span class="arrow-tail" aria-hidden="true"></span>
          </a>
          <a class="contact-line" href="mailto:info@entropica-lab.com">info@entropica-lab.com</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero { padding: 96px 0 64px; }
  .hero .eyebrow { font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; margin-bottom: 24px; font-weight: 400; }
  .hero-h { font-size: clamp(34px, 5vw, 60px); line-height: 1.05; letter-spacing: -0.025em; margin: 0 0 28px; font-weight: 300; max-width: 22ch; text-wrap: balance; }
  .hero-lede { font-size: clamp(17px, 1.4vw, 19px); line-height: 1.6; color: var(--mute-on-paper); max-width: 64ch; margin: 0; font-weight: 300; }

  .bio { padding: 72px 0; border-top: 1px solid var(--line-on-paper); }
  .bio-grid { display: grid; grid-template-columns: 320px 1fr; gap: 64px; }
  .portrait img { width: 100%; height: auto; aspect-ratio: 4 / 5; object-fit: cover; background: var(--paper-2); border: 1px solid var(--line-on-paper); display: block; }
  .portrait-caption { margin-top: 16px; }
  .portrait-caption .eyebrow { font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; font-weight: 400; margin-bottom: 6px; }
  .portrait-caption .name { font-size: 20px; letter-spacing: -0.01em; font-weight: 300; }
  .portrait-caption .role { font-size: 12px; color: var(--mute-on-paper); margin-top: 4px; font-weight: 300; }
  .bio-text { max-width: 64ch; }
  .bio-text .lede { font-size: 22px; line-height: 1.4; font-weight: 300; color: var(--ink-on-paper); margin-bottom: 24px; }
  .bio-text h2 { font-size: 14px; text-transform: uppercase; letter-spacing: 0.12em; color: var(--mute-on-paper-2); font-weight: 400; margin-top: 40px; margin-bottom: 12px; }
  .bio-text .muted { color: var(--mute-on-paper); }
  @media (max-width: 900px) { .bio-grid { grid-template-columns: 1fr; gap: 32px; } .portrait img { max-width: 360px; } }

  .block { padding: 80px 0; border-top: 1px solid var(--line-on-paper); }
  .block.alt { background: var(--paper-2); }
  .proof-head { margin-bottom: 48px; }
  .proof-head .eyebrow { font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; font-weight: 400; margin-bottom: 16px; }
  .block-h { font-size: clamp(26px, 3vw, 38px); line-height: 1.15; letter-spacing: -0.02em; margin: 0; font-weight: 300; max-width: 24ch; text-wrap: balance; }
  .cv-stack { display: grid; gap: 0; }
  .cv-row { display: grid; grid-template-columns: 180px 280px 1fr; gap: 32px; align-items: baseline; padding: 22px 0; border-top: 1px solid var(--line-on-paper); }
  /* no border-bottom on last cv-row, the following .block adds its own border-top */
  .cv-period { font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--mute-on-paper-2); font-weight: 400; }
  .cv-role { font-size: 16px; font-weight: 400; }
  .cv-org { font-size: 12px; color: var(--mute-on-paper); margin-top: 4px; font-weight: 300; }
  .cv-body { font-size: 14px; line-height: 1.6; color: var(--mute-on-paper); font-weight: 300; max-width: 52ch; }
  @media (max-width: 900px) { .cv-row { grid-template-columns: 1fr; gap: 8px; } }

  .philosophy-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 32px; }
  .philosophy-grid > div .eyebrow { font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; font-weight: 400; margin-bottom: 10px; }
  .phil-h { font-size: 19px; font-weight: 400; margin: 0 0 8px; }
  .phil-body { font-size: 14px; line-height: 1.55; color: var(--mute-on-paper); font-weight: 300; margin: 0; }
  @media (max-width: 900px) { .philosophy-grid { grid-template-columns: 1fr 1fr; gap: 24px; } }
  @media (max-width: 540px) { .philosophy-grid { grid-template-columns: 1fr; } }

  .closing-cta { padding: 96px 0; border-top: 1px solid var(--line-on-paper); }
  .closing-inner { max-width: 800px; }
  .closing-h { font-size: clamp(28px, 3.5vw, 44px); line-height: 1.15; letter-spacing: -0.02em; margin: 0 0 32px; font-weight: 300; text-wrap: balance; }
  .closing-ctas { display: flex; align-items: center; gap: 24px; flex-wrap: wrap; }
  .contact-line { font-size: 14px; color: var(--mute-on-paper); border-bottom: 1px solid transparent; padding: 4px 0; }
  .contact-line:hover { color: var(--amber); border-bottom-color: var(--amber); }
</style>
