---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import { localized, tr } from '../../i18n/utils';

const locale = 'es' as const;
const t = tr(locale);

export async function getStaticPaths() {
  const all = await getCollection('blog', ({ data }) => data.locale === 'es' && !data.draft);
  return all.map((entry) => ({ params: { slug: entry.data.slug }, props: { entry } }));
}

const { entry } = Astro.props;
const { data } = entry;
const { Content } = await render(entry);
const fmt = new Intl.DateTimeFormat('es-PA', { year: 'numeric', month: 'long', day: 'numeric' });

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: data.title,
  description: data.summary,
  datePublished: data.date.toISOString(),
  author: { '@type': 'Person', name: data.author ?? 'josé barría', url: 'https://entropica-lab.com/about' },
  publisher: { '@type': 'Organization', name: 'entrópica', url: 'https://entropica-lab.com' },
  ...(data.heroImage ? { image: new URL(data.heroImage, Astro.site).toString() } : {}),
  inLanguage: 'es',
};
---

<BaseLayout title={`${data.title} · entrópica apuntes`} description={data.summary} locale={locale} ogImage={data.heroImage}>
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <article class="post">
    <div class="site-wrap">
      <div class="crumb">
        <a href={localized('/blog', locale)}>{t('cta.back')} {t('nav.journal')}</a>
      </div>

      <header class="post-head">
        <div class="eyebrow amber">{data.eyebrow ?? '// apuntes'}</div>
        <h1 class="post-h1">{data.title}</h1>
        <p class="post-lede">{data.summary}</p>
      </header>

      {data.heroImage && (
        <figure class="post-hero">
          <img src={data.heroImage} alt={data.title} loading="eager" />
        </figure>
      )}

      <div class="post-band">
        {data.categories && data.categories.length > 0 && (
          <div class="band-cell">
            <div class="k">{t('blog.categories')}</div>
            <div class="v">{data.categories.join(', ')}</div>
          </div>
        )}
        {data.tags && data.tags.length > 0 && (
          <div class="band-cell">
            <div class="k">{t('blog.tags')}</div>
            <div class="v">{data.tags.join(', ')}</div>
          </div>
        )}
        {data.keywords && data.keywords.length > 0 && (
          <div class="band-cell">
            <div class="k">{t('blog.keywords')}</div>
            <div class="v">{data.keywords.join(', ')}</div>
          </div>
        )}
        <div class="band-cell">
          <div class="k">{t('blog.published')}</div>
          <div class="v"><time datetime={data.date.toISOString()}>{fmt.format(data.date)}</time></div>
        </div>
      </div>

      <div class="post-narr">
        <div class="narr-side">
          <div class="eyebrow">// la nota</div>
          <div class="narr-by">{data.author}</div>
        </div>
        <div class="post-body prose"><Content /></div>
      </div>

      <footer class="post-foot">
        <a class="btn" href={localized('/blog', locale)}>{t('cta.back')} {t('nav.journal')}</a>
      </footer>
    </div>
  </article>
</BaseLayout>

<style>
  .post { padding: 24px 0 96px; }
  .crumb { padding: 8px 0 48px; font-size: 11px; letter-spacing: 0.08em; color: var(--mute-on-paper); }
  .crumb a { color: var(--mute-on-paper); border-bottom: 1px solid transparent; }
  .crumb a:hover { color: var(--amber); border-bottom-color: var(--amber); }

  .post-head { max-width: 820px; margin-bottom: 40px; }
  .post-head .eyebrow { font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; font-weight: 400; margin-bottom: 20px; display: inline-block; }
  .post-h1 { font-size: clamp(32px, 5vw, 56px); line-height: 1.05; letter-spacing: -0.025em; margin: 0 0 24px; font-weight: 300; text-wrap: balance; }
  .post-lede { font-size: clamp(17px, 1.6vw, 20px); line-height: 1.55; color: var(--mute-on-paper); font-weight: 300; margin: 0; max-width: 60ch; }

  .post-hero { margin: 0 0 40px; padding: 0; width: 100%; aspect-ratio: 16 / 10; overflow: hidden; background: var(--paper-2); border: 1px solid var(--line-on-paper); }
  .post-hero img { width: 100%; height: 100%; object-fit: cover; display: block; }

  /* info band, mirrors the project meta band */
  .post-band { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; padding: 24px 0; margin-bottom: 56px; border-top: 1px solid var(--line-on-paper); border-bottom: 1px solid var(--line-on-paper); }
  .post-band .k { font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--mute-on-paper-2); margin-bottom: 6px; font-weight: 400; }
  .post-band .v { font-size: 13px; font-weight: 400; line-height: 1.5; }
  @media (max-width: 900px) { .post-band { grid-template-columns: 1fr 1fr; gap: 16px; } }

  /* chapters: label-left / text-right, mirroring the project narr-grid */
  .post-narr { display: grid; grid-template-columns: 220px 1fr; gap: 64px; }
  .narr-side { position: sticky; top: calc(var(--header-h) + 24px); align-self: start; }
  .narr-side .eyebrow { font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; font-weight: 400; margin-bottom: 12px; display: block; }
  .narr-by { font-size: 12px; color: var(--mute-on-paper); font-weight: 400; }
  @media (max-width: 900px) { .post-narr { grid-template-columns: 1fr; gap: 24px; } .narr-side { position: static; } }

  .post-body { max-width: 64ch; }

  /* h2 as chapter divider with // prefix */
  .post-body :global(h2) {
    font-size: 24px; font-weight: 400; letter-spacing: -0.01em; line-height: 1.25;
    margin: 56px 0 20px; padding-top: 32px;
    border-top: 1px solid var(--line-on-paper);
    color: var(--ink-on-paper);
  }
  .post-body :global(h2:first-child) { margin-top: 0; padding-top: 0; border-top: none; }
  .post-body :global(h2)::before { content: '// '; color: var(--mute-on-paper-2); font-weight: 400; margin-right: 2px; }

  /* h3 as sub-eyebrow */
  .post-body :global(h3) {
    font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; font-weight: 500;
    color: var(--mute-on-paper-2); margin: 36px 0 12px;
  }

  .post-body :global(p) { font-size: 17px; line-height: 1.75; font-weight: 400; margin: 0 0 18px; color: var(--ink-on-paper); }

  /* opening blockquote as pull-quote */
  .post-body :global(blockquote) {
    border-left: 2px solid var(--amber); padding: 4px 0 4px 20px; margin: 0 0 32px;
    font-size: 22px; line-height: 1.35; font-weight: 300; letter-spacing: -0.005em;
    color: var(--ink-on-paper); font-style: normal; max-width: 32ch;
  }
  .post-body :global(blockquote p) { font-size: inherit; line-height: inherit; font-weight: inherit; margin: 0; }

  .post-body :global(ul), .post-body :global(ol) { font-size: 17px; line-height: 1.7; font-weight: 400; padding-left: 22px; margin: 0 0 18px; }
  .post-body :global(li) { margin-bottom: 6px; }
  .post-body :global(ul li)::marker { color: var(--amber); }

  .post-body :global(strong), .post-body :global(b) { color: var(--ink-on-paper); font-weight: 500; }
  .post-body :global(em), .post-body :global(i) { font-style: normal; color: var(--mute-on-paper); }

  .post-body :global(hr) { border: none; border-top: 1px solid var(--line-on-paper); margin: 56px 0 40px; }

  .post-body :global(code) { font-family: var(--font-mono); background: var(--paper-2); border: 1px solid var(--line-on-paper); padding: 1px 6px; font-size: 0.92em; }
  .post-body :global(a) { color: inherit; border-bottom: 1px solid var(--line-on-paper-2); }
  .post-body :global(a:hover) { color: var(--amber); border-bottom-color: var(--amber); }

  .post-foot { margin-top: 80px; padding-top: 32px; border-top: 1px solid var(--line-on-paper); }
</style>
