---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { localized } from '../../i18n/utils';

const locale = 'es' as const;

const all = await getCollection('blog', ({ data }) => data.locale === locale && !data.draft);
const posts = all.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const fmt = new Intl.DateTimeFormat('es-PA', { year: 'numeric', month: 'long', day: 'numeric' });

// Map categories to filter topics
function getTopic(categories: string[] = []): string {
  if (categories.some((c) => c === 'guía' || c === 'guias')) return 'guides';
  if (categories.some((c) => c === 'estudios de caso')) return 'case-studies';
  if (categories.some((c) => c === 'especulativo' || c === 'facc')) return 'climate-futures';
  return '';
}
---

<BaseLayout
  title="recursos · entrópica · arquitectura tropical en panamá"
  description="herramientas, guías y apuntes para que arquitectos, promotores y consultores integren el desempeño energético desde el inicio. adaptaciones climáticas, estudios de caso y guías de diseño bioclimático en panamá."
  locale={locale}
>
  <section class="hero">
    <div class="site-wrap">
      <div class="eyebrow">// recursos</div>
      <h1 class="hero-h">el conocimiento ayuda a exigir mejores edificios.</h1>
      <p class="hero-lede">
        creemos que el conocimiento debe ser abierto. esta sección reúne herramientas,
        guías y apuntes para que arquitectos, promotores y consultores integren el
        desempeño energético en sus proyectos. desde plantillas de benchmarking y flujos
        de simulación hasta explicaciones en lenguaje sencillo. úsalos para aprender,
        adaptar y exigir mejores edificios.
      </p>
      <div class="topics-line">
        <span class="topics-label">nuestros temas:</span>
        adaptaciones futuras al cambio climático · estudios de caso · guías
      </div>
    </div>
  </section>

  <section class="resources-section">
    <div class="site-wrap">
      <div class="filter-bar" role="group" aria-label="filtrar por tema">
        <button class="filter-btn active" data-topic="all">todos</button>
        <button class="filter-btn" data-topic="guides">guías</button>
        <button class="filter-btn" data-topic="case-studies">estudios de caso</button>
        <button class="filter-btn" data-topic="climate-futures">futuros climáticos</button>
      </div>

      {posts.length === 0 ? (
        <p class="empty">pronto habrá publicaciones. vuelve en breve.</p>
      ) : (
        <div class="res-grid">
          {posts.map((post) => {
            const topic = getTopic(post.data.categories);
            return (
              <a
                class="res-card"
                href={localized(`/blog/${post.data.slug}`, locale)}
                data-topics={topic}
              >
                <div class="res-img">
                  {post.data.heroImage ? (
                    <img src={post.data.heroImage} alt={post.data.title} loading="lazy" />
                  ) : (
                    <span class="ph-tag">// {post.data.categories?.[0] ?? 'recursos'}</span>
                  )}
                </div>
                <div class="res-meta">
                  <div class="res-eb">{post.data.eyebrow ?? '// recursos'}</div>
                  <h2 class="res-title">{post.data.title}</h2>
                  <p class="res-summary">{post.data.summary}</p>
                  <time class="res-date" datetime={post.data.date.toISOString()}>
                    {fmt.format(post.data.date)}
                  </time>
                </div>
              </a>
            );
          })}
        </div>
      )}
    </div>
  </section>
</BaseLayout>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const cards = document.querySelectorAll<HTMLElement>('.res-card');
  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const topic = btn.dataset.topic ?? 'all';
      buttons.forEach((b) => b.classList.remove('active'));
      btn.classList.add('active');
      cards.forEach((card) => {
        const match = topic === 'all' || card.dataset.topics === topic;
        (card as HTMLElement).style.display = match ? '' : 'none';
      });
    });
  });
</script>

<style>
  .hero { padding: 96px 0 56px; }
  .hero .eyebrow { font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; margin-bottom: 24px; font-weight: 400; }
  .hero-h { font-size: clamp(34px, 5vw, 60px); line-height: 1.05; letter-spacing: -0.025em; margin: 0 0 28px; font-weight: 300; max-width: 26ch; text-wrap: balance; }
  .hero-lede { font-size: clamp(17px, 1.4vw, 19px); line-height: 1.6; color: var(--mute-on-paper); max-width: 64ch; margin: 0 0 24px; font-weight: 300; }
  .topics-line { font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--mute-on-paper-2); font-weight: 400; }
  .topics-label { color: var(--mute-on-paper); margin-right: 8px; }

  .resources-section { padding: 24px 0 96px; }

  .filter-bar { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 48px; }
  .filter-btn { background: none; border: 1px solid var(--line-on-paper); color: var(--mute-on-paper); font-family: inherit; font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; font-weight: 400; padding: 8px 16px; cursor: pointer; transition: all 0.15s; }
  .filter-btn:hover { border-color: var(--mute-on-paper); color: var(--ink-on-paper); }
  .filter-btn.active { border-color: var(--amber); color: var(--ink-on-paper); background: transparent; }

  .res-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 32px; }
  .res-card { display: flex; flex-direction: column; gap: 0; color: inherit; text-decoration: none; border: 1px solid var(--line-on-paper); transition: border-color 0.15s; }
  .res-card:hover { border-color: var(--mute-on-paper); }
  .res-img { aspect-ratio: 16 / 9; background: var(--paper-2); background-image: repeating-linear-gradient(135deg, rgba(0,0,0,0.03) 0 12px, transparent 12px 24px); position: relative; overflow: hidden; flex-shrink: 0; }
  .res-img img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; display: block; }
  .res-img .ph-tag { position: absolute; top: 14px; left: 16px; font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--mute-on-paper-2); font-weight: 400; }
  .res-meta { padding: 24px; display: flex; flex-direction: column; gap: 10px; flex: 1; }
  .res-eb { font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--mute-on-paper-2); font-weight: 400; }
  .res-title { font-size: 22px; line-height: 1.15; letter-spacing: -0.015em; font-weight: 300; margin: 0; }
  .res-card:hover .res-title { color: var(--ink-on-paper); }
  .res-summary { font-size: 14px; line-height: 1.6; color: var(--mute-on-paper); font-weight: 300; margin: 0; flex: 1; }
  .res-date { font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--mute-on-paper-2); font-weight: 400; margin-top: 4px; }

  .empty { padding: 64px 0; color: var(--mute-on-paper); font-style: italic; font-weight: 300; }

  @media (max-width: 700px) { .res-grid { grid-template-columns: 1fr; } }
</style>
