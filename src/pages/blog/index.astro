---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { localized } from '../../i18n/utils';

const locale = 'en' as const;

const all = await getCollection('blog', ({ data }) => data.locale === locale && !data.draft);
const posts = all.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const fmt = new Intl.DateTimeFormat('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout
  title="journal · entrópica"
  description="notes from the studio on simulation, tropical building, and the work of asking the model before drawing the section."
  locale={locale}
>
  <section class="hero">
    <div class="site-wrap">
      <div class="eyebrow">// the journal</div>
      <h1 class="hero-h">notes from the studio.</h1>
      <p class="hero-lede">
        short pieces on the work, simulation, envelope, tropical building, and the
        ideas that keep the practice honest. published when there's something to say
        and not before.
      </p>
    </div>
  </section>

  <section class="posts">
    <div class="site-wrap">
      {posts.length === 0 ? (
        <p class="empty">no posts yet. check back soon.</p>
      ) : (
        <div class="post-list">
          {posts.map((post) => (
            <a class="post-row" href={localized(`/blog/${post.data.slug}`, locale)}>
              <div class="post-date">
                <time datetime={post.data.date.toISOString()}>{fmt.format(post.data.date)}</time>
              </div>
              <div class="post-meta">
                <div class="post-eb">{post.data.eyebrow ?? '// the journal'}</div>
                <h2 class="post-title">{post.data.title}</h2>
                <p class="post-summary">{post.data.summary}</p>
              </div>
              <div class="post-arrow">
                <span class="arrow-tail" aria-hidden="true"></span>
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding: 96px 0 64px;
  }
  .hero .eyebrow {
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin-bottom: 24px;
    font-weight: 400;
  }
  .hero-h {
    font-size: clamp(34px, 5vw, 60px);
    line-height: 1.05;
    letter-spacing: -0.025em;
    margin: 0 0 28px;
    font-weight: 300;
    max-width: 24ch;
    text-wrap: balance;
  }
  .hero-lede {
    font-size: clamp(17px, 1.4vw, 19px);
    line-height: 1.6;
    color: var(--mute-on-paper);
    max-width: 60ch;
    margin: 0;
    font-weight: 300;
  }

  .posts { padding: 24px 0 96px; }
  .empty {
    padding: 64px 0;
    color: var(--mute-on-paper);
    font-style: italic;
    font-weight: 300;
  }

  .post-list { display: grid; gap: 0; }
  .post-row {
    display: grid;
    grid-template-columns: 180px 1fr 60px;
    gap: 48px;
    padding: 40px 0;
    border-top: 1px solid var(--line-on-paper);
    color: inherit;
    text-decoration: none;
    align-items: start;
    transition: background 0.15s;
  }
  .post-row:hover { background: var(--paper-2); }
  .post-row:last-child { border-bottom: 1px solid var(--line-on-paper); }
  .post-date time {
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--mute-on-paper-2);
    font-weight: 400;
  }
  .post-meta { display: flex; flex-direction: column; gap: 8px; }
  .post-eb {
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--mute-on-paper-2);
    font-weight: 400;
  }
  .post-title {
    font-size: 24px;
    line-height: 1.15;
    letter-spacing: -0.015em;
    font-weight: 300;
    margin: 0;
  }
  .post-summary {
    font-size: 15px;
    line-height: 1.55;
    color: var(--mute-on-paper);
    font-weight: 300;
    margin: 0;
    max-width: 56ch;
  }
  .post-arrow {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    padding-top: 6px;
    color: var(--mute-on-paper-2);
  }
  .post-row:hover .post-arrow { color: var(--amber); }
  @media (max-width: 700px) {
    .post-row { grid-template-columns: 1fr; gap: 8px; }
    .post-arrow { display: none; }
  }
</style>
