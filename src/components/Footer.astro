---
import { tr, localized } from '../i18n/utils';
import type { Locale } from '../i18n/strings';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = tr(locale);
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="inner">
    <div class="brand">
      <a href={localized('/', locale)} aria-label="entrópica">
        <img src="/entropica-dark.png" alt="entrópica" width="220" height="62" />
      </a>
      <div class="tag">{t('footer.bio')}</div>
    </div>

    <div class="col">
      <h4>{t('footer.studio')}</h4>
      <ul>
        <li><a href={localized('/about', locale)}>{t('nav.about')}</a></li>
        <li><a href={localized('/services', locale)}>{t('nav.services')}</a></li>
        <li><a href={localized('/projects', locale)}>{t('nav.work')}</a></li>
        <li><a href={localized('/blog', locale)}>{t('nav.journal')}</a></li>
      </ul>
    </div>

    <div class="col">
      <h4>{t('footer.contact')}</h4>
      <ul>
        <li><a href="mailto:info@entropica-lab.com">info@entropica-lab.com</a></li>
        <li><a href="https://wa.me/50769444740" target="_blank" rel="noopener">+507 6944-4740 · whatsapp</a></li>
        <li><a href="https://instagram.com/entropicalab" rel="noopener" target="_blank">@entropicalab</a></li>
        <li>{t('footer.address')}</li>
      </ul>
    </div>
  </div>

  <div class="legal">
    <div>{t('footer.copyright')} · {year}</div>
    <div>{t('footer.legal')}</div>
  </div>
</footer>
